
@section Styles {
    <link rel="stylesheet" href="~/css/pages/orders-index.css" asp-append-version="true" />
}
﻿@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Pedidos";
}

<div class="page-shell orders-page">
    <div class="page-header orders-header">
        <div>
            <h1 class="orders-title">
                <i class="fas fa-clipboard-list"></i>
                Gestión de pedidos
            </h1>
            <p class="text-muted orders-subtitle">
                Pedidos creados desde web, POS y otros canales, con seguimiento centralizado.
            </p>
        </div>

        <div class="orders-filters">
            <input id="ordersSearch" class="form-control" placeholder="Buscar por cliente o pedido" />
            <select id="ordersStatus" class="form-control orders-status-filter">
                <option value="Todos">Todos los estados</option>
                <option>Pendiente pago</option>
                <option>Confirmado</option>
                <option>En producción</option>
                <option>Listo</option>
                <option>En camino</option>
                <option>Entregado</option>
            </select>
        </div>
    </div>

    <div class="grid grid-4 orders-kpi-grid">
        <div class="card orders-kpi-card">
            <div class="text-muted">Total pedidos</div>
            <h2 id="ordersTotal"></h2>
        </div>

        <div class="card orders-kpi-card">
            <div class="text-muted">Pendientes de pago</div>
            <h2 id="ordersPending"></h2>
        </div>

        <div class="card orders-kpi-card">
            <div class="text-muted">En producción</div>
            <h2 id="ordersProduction"></h2>
        </div>

        <div class="card orders-kpi-card">
            <div class="text-muted">Ventas cerradas</div>
            <h2 id="ordersSales"></h2>
        </div>
    </div>

    <div class="card orders-table-card">
        <div class="orders-section-header">
            <h3 class="orders-section-title">Pedidos</h3>
        </div>

        <div class="table-container orders-table-wrap">
            <table class="table orders-table">
                <thead>
                    <tr>
                        <th>Pedido</th>
                        <th>Cliente</th>
                        <th>Canal</th>
                        <th>Entrega</th>
                        <th>Estado</th>
                        <th>Pago</th>
                        <th>Total</th>
                        <th class="text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody id="ordersTable"></tbody>
            </table>
        </div>
    </div>
</div>



@section Scripts {
    <script>
        (() => {
            const search = document.getElementById('ordersSearch');
            const status = document.getElementById('ordersStatus');
            let orders = [];
            let pageInitialized = false;

            function getStatusClass(value) {
                switch (value) {
                    case 'Pendiente pago': return 'status-pending';
                    case 'Confirmado': return 'status-confirmed';
                    case 'En produccion': return 'status-production';
                    case 'En producción': return 'status-production';
                    case 'Listo': return 'status-ready';
                    case 'En camino': return 'status-route';
                    case 'Entregado': return 'status-delivered';
                    default: return '';
                }
            }

            function getPaymentMethodClass(value) {
                switch ((value || '').toLowerCase()) {
                    case 'efectivo': return 'method-cash';
                    case 'transferencia': return 'method-transfer';
                    case 'sinpe': return 'method-sinpe';
                    case 'tarjeta': return 'method-card';
                    default: return '';
                }
            }

            function normalizeOrder(o) {
                return {
                    id: o.id,
                    customerName: o.cliente || o.customerName || '-',
                    customerEmail: o.customerEmail || '',
                    channel: o.canal || o.channel || '-',
                    deliveryDate: o.entrega || o.deliveryDate,
                    status: o.estado || o.status || '-',
                    paymentStatus: o.paymentStatus || '-',
                    paymentMethod: o.paymentMethod || '',
                    total: Number(o.total || 0),
                    productId: Number(o.productId || 0),
                    quantity: Number(o.quantity || 1),
                    unitPrice: Number(o.unitPrice || 0),
                    producto: o.producto || '',
                    createdAt: o.createdAt || o.entrega || new Date().toISOString()
                };
            }

            async function loadOrders() {
                orders = (await fetch('/api/orders').then(r => r.json())).map(normalizeOrder);
            }

            function render() {
                const all = orders;

                document.getElementById('ordersTotal').textContent = all.length;
                document.getElementById('ordersPending').textContent = all.filter(x => x.paymentStatus !== 'Pagado').length;
                document.getElementById('ordersProduction').textContent = all.filter(x => x.status === 'En producción').length;
                document.getElementById('ordersSales').textContent = all.filter(x => x.paymentStatus === 'Pagado').length;

                const q = search.value.trim().toLowerCase();
                const st = status.value;

                const rows = all.filter(o =>
                    (!q || o.customerName.toLowerCase().includes(q) || String(o.id).includes(q)) &&
                    (st === 'Todos' || o.status === st)
                );

                document.getElementById('ordersTable').innerHTML = rows.map(o => `
                    <tr>
                        <td>
                            <strong>#${o.id}</strong>
                            <div class="text-muted orders-order-meta">${new Date(o.createdAt).toLocaleString('es-CR')}</div>
                        </td>
                        <td>
                            ${o.customerName}
                            <div class="text-muted orders-customer-meta">${o.customerEmail || '-'}</div>
                        </td>
                        <td>${o.channel}</td>
                        <td>${new Date(o.deliveryDate).toLocaleDateString('es-CR')}</td>
                        <td>
                            <span class="orders-status-badge ${getStatusClass(o.status)}">
                                ${o.status}
                            </span>
                        </td>
                        <td>
                            <div class="orders-payment-cell">
                                <span class="badge ${o.paymentStatus === 'Pagado' ? 'badge-success' : 'badge-warning'}">
                                    ${o.paymentStatus}
                                </span>
                                ${o.paymentMethod
                                    ? `<span class="orders-payment-method ${getPaymentMethodClass(o.paymentMethod)}">${o.paymentMethod}</span>`
                                    : `<span class="text-muted orders-order-meta">Sin método</span>`}
                            </div>
                        </td>
                        <td>${app.utils.formatCurrency(o.total)}</td>
                        <td class="text-right">
                            <div class="orders-actions-cell">
                                <select onchange="changeStatus(${o.id}, this.value)" class="form-control">
                                    ${['Pendiente pago','Confirmado','En producción','Listo','En camino','Entregado']
                                        .map(s => `<option ${s === o.status ? 'selected' : ''}>${s}</option>`)
                                        .join('')}
                                </select>
                                ${o.paymentStatus !== 'Pagado'
                                    ? `<button class="btn btn-outline btn-sm" onclick="chargeOrder(${o.id})"><i class="fas fa-credit-card"></i> Cobrar</button>`
                                    : ''}
                                <button class="btn btn-ghost btn-sm" style="color:var(--danger);" onclick="deleteOrder(${o.id})">
                                    <i class="fas fa-trash-can"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `).join('') || `
                    <tr>
                        <td colspan="8" class="text-center text-muted">No hay pedidos.</td>
                    </tr>
                `;
            }

            window.changeStatus = (id, value) => {
                try {
                    fetch(`/api/orders/${id}/status`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ status: value })
                    }).then(async response => {
                        if (!response.ok) throw new Error(await response.text());
                        await loadOrders();
                        render();
                    }).catch(error => app.toast.error(error.message));
                    if (value === 'En camino') {
                        app.toast.info('El pedido ya puede visualizarse en el mapa en tiempo real.');
                    }
                } catch (error) {
                    app.toast.error(error.message);
                }
            };

            window.chargeOrder = (id) => {
                const order = orders.find(item => Number(item.id) === Number(id));
                if (!order) return;

                const cartItem = {
                    productId: Number(order.productId),
                    name: order.producto || 'Pedido',
                    code: `PED-${order.id}`,
                    unitPrice: Number(order.unitPrice || order.total || 0),
                    quantity: Number(order.quantity || 1)
                };

                sessionStorage.setItem('bakesmart.pos.pendingOrder', JSON.stringify({
                    id: order.id,
                    customerName: order.customerName || '',
                    customerEmail: order.customerEmail || '',
                    paymentMethod: order.paymentMethod || 'Tarjeta',
                    total: Number(order.total || 0),
                    item: cartItem
                }));
                sessionStorage.setItem('bakesmart.pos.cart', JSON.stringify([cartItem]));
                window.location.assign('/Pos/Cart?orderId=' + encodeURIComponent(order.id));
            };

            window.deleteOrder = (id) => {
                if (!confirm(`Eliminar pedido #${id}? Esto lo quitara del cliente, rastreo y flujo operativo.`)) return;

                fetch(`/api/orders/${id}`, {
                    method: 'DELETE'
                }).then(async response => {
                    if (!response.ok) throw new Error(await response.text());
                    await loadOrders();
                    app.toast.success(`Pedido #${id} eliminado.`);
                    render();
                }).catch(error => app.toast.error(error.message));
            };

            search.addEventListener('input', render);
            status.addEventListener('change', render);

            async function initializePage() {
                if (pageInitialized) return;
                pageInitialized = true;
                await loadOrders();
                render();
            }

            app.page.ready(initializePage);
        })();
    </script>
}
