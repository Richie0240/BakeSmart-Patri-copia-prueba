@model BakeSmartPatri.Models.CatalogIndexViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Inicio";
    var isAuth = User?.Identity?.IsAuthenticated ?? false;
    var isAdmin = User?.IsInRole("Admin") ?? false;
    var isStaff = User?.IsInRole("Staff") ?? false;
    var isClient = User?.IsInRole("Cliente") ?? false;
    var culture = new System.Globalization.CultureInfo("es-CR");
    var products = Model.Products.Where(product => product.IsActive).ToList();
    var heroProduct = products.FirstOrDefault();
    var categoryCards = Model.Categories
        .Take(5)
        .Select(category => new
        {
            Category = category,
            Product = products.FirstOrDefault(product => product.Category == category.Name)
        })
        .ToList();
    var offerProducts = products.Skip(1).Take(3).ToList();
    var popularProducts = products.Take(5).ToList();
}

@if (!isAuth)
{
    <div class="storefront-page">
        <section class="storefront-hero">
            <div class="container storefront-hero-grid">
                <div class="storefront-hero-copy">
                    <span class="storefront-eyebrow">Especial de temporada</span>
                    <h1>Endulza <strong>tu día</strong></h1>
                    <p>Repostería artesanal preparada con detalle, ingredientes seleccionados y ese toque especial que convierte cualquier momento en celebración.</p>
                    <div class="storefront-code">
                        <span>Descubre nuestras creaciones</span>
                        <strong>BAKESMART</strong>
                    </div>
                    <a class="storefront-primary-action" href="/Catalog">
                        Ver productos
                        <i class="fas fa-bag-shopping"></i>
                    </a>
                </div>

                <div class="storefront-hero-visual">
                    <span class="storefront-doodle storefront-doodle-one">♡</span>
                    <span class="storefront-doodle storefront-doodle-two">✦</span>
                    <div class="storefront-hero-photo">
                        <img src="@(heroProduct?.ImageUrl ?? "/img/products/cupcakes-decorados.jpg")"
                             alt="@(heroProduct?.AltText ?? "Repostería artesanal BakeSmart Patri")"
                             width="720" height="720" decoding="async" fetchpriority="high"
                             onerror="this.src='/img/products/producto-sin-imagen.svg';" />
                    </div>
                    <div class="storefront-love-seal">
                        <span>Hechos</span>
                        <strong>con amor</strong>
                        <i class="far fa-heart"></i>
                    </div>
                </div>
            </div>
        </section>

        <section class="storefront-section storefront-categories" id="categorias">
            <div class="container">
                <div class="storefront-heading storefront-heading-compact">
                    <span></span>
                    <h2>Elige tu favorito</h2>
                    <span></span>
                </div>
                <div class="storefront-category-grid">
                    @foreach (var item in categoryCards)
                    {
                        <a class="storefront-category-card" href="/Catalog?category=@Uri.EscapeDataString(item.Category.Name)">
                            <span class="storefront-category-image">
                                <img src="@(item.Product?.ImageUrl ?? "/img/products/producto-sin-imagen.svg")"
                                     alt="@item.Category.Name"
                                     width="180" height="180" loading="lazy" decoding="async"
                                     onerror="this.src='/img/products/producto-sin-imagen.svg';" />
                            </span>
                            <strong>@item.Category.Name</strong>
                            <small>Ver más</small>
                        </a>
                    }
                </div>
            </div>
        </section>

        <section class="storefront-section storefront-offers" id="ofertas">
            <div class="container">
                <div class="storefront-heading">
                    <span></span>
                    <h2>Ofertas que te van a encantar</h2>
                    <span></span>
                </div>
                <div class="storefront-offer-grid">
                    @foreach (var product in offerProducts)
                    {
                        <article class="storefront-offer-card">
                            <div class="storefront-offer-copy">
                                <span>@product.Category</span>
                                <h3>@product.Name</h3>
                                <strong>@product.UnitPrice.ToString("C0", culture)</strong>
                                <a href="/Catalog/Details/@product.Id">Ver oferta</a>
                            </div>
                            <img src="@product.ImageUrl" alt="@product.AltText" width="420" height="240" loading="lazy" decoding="async" onerror="this.src='/img/products/producto-sin-imagen.svg';" />
                        </article>
                    }
                </div>
            </div>
        </section>

        <section class="storefront-section storefront-popular" id="populares">
            <div class="container">
                <div class="storefront-heading storefront-heading-link">
                    <span></span>
                    <h2>Productos populares</h2>
                    <a href="/Catalog/Popular">Ver todos <i class="fas fa-arrow-right"></i></a>
                </div>
                <div class="storefront-product-grid">
                    @foreach (var product in popularProducts)
                    {
                        <article class="storefront-product-card">
                            <a class="storefront-product-image" href="/Catalog/Details/@product.Id">
                                <img src="@product.ImageUrl" alt="@product.AltText" width="480" height="420" loading="lazy" decoding="async" onerror="this.src='/img/products/producto-sin-imagen.svg';" />
                                <span><i class="far fa-heart"></i></span>
                            </a>
                            <div class="storefront-product-body">
                                <small>@product.Category</small>
                                <h3>@product.Name</h3>
                                <div class="storefront-rating" aria-label="Valoración de cinco estrellas">
                                    <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                                </div>
                                <strong>@product.UnitPrice.ToString("C0", culture)</strong>
                                <a href="/Catalog?add=@product.Id">Agregar al carrito <i class="fas fa-cart-plus"></i></a>
                            </div>
                        </article>
                    }
                </div>
            </div>
        </section>

        <section class="storefront-section storefront-reviews">
            <div class="container">
                <div class="storefront-heading">
                    <span></span>
                    <h2>Lo que hace especial cada pedido</h2>
                    <span></span>
                </div>
                <div class="storefront-review-grid">
                    <article><i class="fas fa-wand-magic-sparkles"></i><div><strong>Acabado artesanal</strong><p>Cada creación se prepara con atención al detalle y una presentación cuidada.</p></div></article>
                    <article><i class="fas fa-leaf"></i><div><strong>Ingredientes seleccionados</strong><p>Sabores equilibrados y productos pensados para disfrutar desde el primer bocado.</p></div></article>
                    <article><i class="fas fa-gift"></i><div><strong>Momentos memorables</strong><p>Opciones para cumpleaños, eventos, regalos y cualquier ocasión especial.</p></div></article>
                </div>
            </div>
        </section>

        <section class="storefront-delivery">
            <div class="container storefront-delivery-grid">
                <div class="storefront-delivery-lead"><i class="fas fa-motorcycle"></i><strong>Entregas rápidas y seguras</strong><span>Coordinamos cada pedido con cuidado.</span></div>
                <div><i class="far fa-clock"></i><span><strong>Atención ágil</strong>Respuesta oportuna</span></div>
                <div><i class="fas fa-shield-heart"></i><span><strong>Empaque seguro</strong>Producto protegido</span></div>
                <div><i class="far fa-face-smile"></i><span><strong>Satisfacción</strong>Servicio cercano</span></div>
            </div>
        </section>

        <section class="storefront-newsletter">
            <div class="container storefront-newsletter-grid">
                <div><i class="fas fa-cake-candles"></i><span><strong>Recibe nuestras novedades</strong>Promociones, productos y fechas especiales.</span></div>
                <form action="/Home/Contact" method="get">
                    <label class="sr-only" for="newsletterEmail">Correo electrónico</label>
                    <input id="newsletterEmail" type="email" name="email" placeholder="Tu correo electrónico" required />
                    <button type="submit">Suscribirme</button>
                </form>
            </div>
        </section>
    </div>
}
else if (isClient)
{
    <section class="home-account-hero">
        <div class="container">
            <span>Hola, @(User?.Identity?.Name ?? "Cliente")</span>
            <h1>Encuentra algo especial para tu próximo momento.</h1>
            <p>Explora el catálogo, revisa tus pedidos y administra tu perfil desde un solo lugar.</p>
            <div><a class="btn btn-primary" href="/Catalog">Explorar catálogo</a><a class="btn btn-outline" href="/Client">Mi espacio</a></div>
        </div>
    </section>
}
else if (isAdmin || isStaff)
{
    <section class="home-account-hero home-account-hero-operations">
        <div class="container">
            <span>Panel operativo</span>
            <h1>Bienvenido, @(User?.Identity?.Name ?? "Usuario")</h1>
            <p>Consulta el estado del negocio y accede rápidamente a las operaciones disponibles para tu rol.</p>
            <div><a class="btn btn-primary" href="/Dashboard">Ir al dashboard</a><a class="btn btn-outline" href="/Orders">Ver pedidos</a></div>
        </div>
    </section>
}
else
{
    <section class="home-account-hero">
        <div class="container"><h1>Bienvenido a BakeSmart Patri</h1><a class="btn btn-primary" href="/Dashboard">Continuar</a></div>
    </section>
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/home-storefront.css" asp-append-version="true" />
}
