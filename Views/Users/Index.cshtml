@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Usuarios";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/users-index.css" asp-append-version="true" />
}

<div class="page-shell users-page">
    <header class="users-hero">
        <div>
            <span class="users-eyebrow">Administracion</span>
            <h1><i class="fas fa-users"></i> Gestion de usuarios</h1>
            <p>Controle altas, roles y estados sin formularios ocupando toda la pantalla.</p>
        </div>
        <div class="users-hero-actions">
            <input id="userSearch" class="form-control" placeholder="Buscar nombre, correo o telefono" />
            <button type="button" id="openUserQuickActions" class="btn btn-primary"><i class="fas fa-user-plus"></i> Nuevo usuario</button>
            <a class="btn btn-outline" href="/Roles"><i class="fas fa-shield-halved"></i> Roles</a>
        </div>
    </header>

    <section class="users-kpis">
        <article><span>Usuarios</span><strong id="usersTotal">0</strong></article>
        <article><span>Activos</span><strong id="usersActive">0</strong></article>
        <article><span>Roles</span><strong id="rolesCount">0</strong></article>
    </section>

    <section class="users-layout">
        <article class="card users-table-card">
            <div class="users-section-head">
                <div>
                    <span class="users-eyebrow">Directorio</span>
                    <h2>Listado de usuarios</h2>
                </div>
                <span class="badge badge-info" id="usersVisibleCount">0 visibles</span>
            </div>
            <div class="table-container users-table-scroll">
                <table class="table users-table">
                    <thead>
                        <tr>
                            <th>Usuario</th>
                            <th>Contacto</th>
                            <th>Rol</th>
                            <th>Estado</th>
                            <th>Creado</th>
                            <th class="text-right">Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="usersTableBody"></tbody>
                </table>
            </div>
        </article>

        <aside class="card users-roles-card">
            <div class="users-section-head">
                <div>
                    <span class="users-eyebrow">Accesos</span>
                    <h2>Roles disponibles</h2>
                </div>
            </div>
            <div id="rolePreview" class="users-role-list"></div>
        </aside>
    </section>
</div>

<template id="userFormTemplate">
    <form id="userForm" class="users-form">
        <input type="hidden" name="id" />
        <div><label>Nombre</label><input class="form-control" name="firstName" required /></div>
        <div><label>Apellidos</label><input class="form-control" name="lastName" required /></div>
        <div><label>Correo</label><input class="form-control" name="email" type="email" required /></div>
        <div><label>Telefono</label><input class="form-control" name="phone" required /></div>
        <div><label>Contrasena</label><input class="form-control" name="password" type="text" placeholder="Minimo 8 caracteres" /></div>
        <div><label>Rol</label><select class="form-control" name="role" id="userRole" required></select></div>
        <div class="users-form-full"><label>Direccion</label><input class="form-control" name="address" /></div>
        <div class="users-form-actions users-form-full">
            <button class="btn btn-outline" type="button" id="clearUserForm">Limpiar</button>
            <button class="btn btn-primary" type="submit"><i class="fas fa-save"></i> Guardar usuario</button>
        </div>
    </form>
</template>

@section Scripts {
<script>
(() => {
    const store = window.BakeSmartStore;
    const body = document.getElementById('usersTableBody');
    const search = document.getElementById('userSearch');
    const rolePreview = document.getElementById('rolePreview');

    const clean = value => String(value ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c]));

    function roleOptions() {
        return store.roles.list().map(r => `<option value="${clean(r.name)}">${clean(r.name)}</option>`).join('');
    }

    function validateUserData(data) {
        for (const field of ['firstName', 'lastName', 'email', 'phone', 'role']) {
            if (!String(data[field] || '').trim()) {
                app.toast.warning('Complete los datos obligatorios.');
                return false;
            }
        }
        if (!/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(String(data.email || '').trim())) {
            app.toast.warning('Ingrese un correo valido.');
            return false;
        }
        if (!data.id && String(data.password || '').trim().length < 8) {
            app.toast.warning('La contrasena debe tener al menos 8 caracteres.');
            return false;
        }
        if (data.id && data.password && String(data.password).trim().length < 8) {
            app.toast.warning('La nueva contrasena debe tener al menos 8 caracteres.');
            return false;
        }
        return true;
    }

    function bindUserForm(item = null) {
        const form = document.getElementById('userForm');
        const roleSelect = document.getElementById('userRole');
        roleSelect.innerHTML = roleOptions();
        if (item) {
            Object.entries(item).forEach(([key, value]) => {
                const input = form.querySelector(`[name="${key}"]`);
                if (input) input.value = value ?? '';
            });
            form.password.value = '';
        }
        form.addEventListener('submit', async e => {
            e.preventDefault();
            const data = Object.fromEntries(new FormData(form).entries());
            if (!validateUserData(data)) return;
            await store.users.save(data);
            app.modal.close();
            app.toast.success(data.id ? 'Usuario actualizado.' : 'Usuario creado.');
            await store.refresh();
            renderRoles();
            renderUsers();
        });
        document.getElementById('clearUserForm')?.addEventListener('click', () => form.reset());
    }

    function renderRoles() {
        const roles = store.roles.list();
        rolePreview.innerHTML = roles.map(r => `
            <article class="users-role-chip">
                <div>
                    <strong>${clean(r.name)}</strong>
                    <span>${clean(r.description || 'Acceso del sistema')}</span>
                </div>
                <b>${(r.permissions || []).length}</b>
            </article>
        `).join('');
        document.getElementById('rolesCount').textContent = roles.length;
    }

    function renderUsers() {
        const all = store.users.list();
        const q = search.value.trim().toLowerCase();
        const users = all.filter(u =>
            !q ||
            `${u.firstName} ${u.lastName}`.toLowerCase().includes(q) ||
            String(u.email || '').toLowerCase().includes(q) ||
            String(u.phone || '').includes(q)
        );

        document.getElementById('usersTotal').textContent = all.length;
        document.getElementById('usersActive').textContent = all.filter(x => x.active).length;
        document.getElementById('usersVisibleCount').textContent = `${users.length} visibles`;

        body.innerHTML = users.map(u => `
            <tr>
                <td><strong>${clean(u.firstName)} ${clean(u.lastName)}</strong><small>${clean(u.address || 'Sin direccion')}</small></td>
                <td><span>${clean(u.email)}</span><small>${clean(u.phone)}</small></td>
                <td><span class="badge badge-primary">${clean(u.role)}</span></td>
                <td><span class="badge ${u.active ? 'badge-success' : 'badge-warning'}">${u.active ? 'Activo' : 'Inactivo'}</span></td>
                <td>${new Date(u.createdAt).toLocaleDateString('es-CR')}</td>
                <td class="text-right">
                    <div class="users-row-actions">
                        <button class="btn btn-outline btn-sm" onclick="editUser(${u.id})"><i class="fas fa-pen"></i></button>
                        <button class="btn btn-outline btn-sm" onclick="toggleUser(${u.id})">${u.active ? 'Desactivar' : 'Activar'}</button>
                    </div>
                </td>
            </tr>
        `).join('') || `<tr><td colspan="6" class="text-center text-muted">No hay usuarios para mostrar.</td></tr>`;
    }

    window.openUserModal = userId => {
        const user = userId ? store.users.list().find(x => Number(x.id) === Number(userId)) : null;
        app.modal.open({ title: user ? 'Editar usuario' : 'Nuevo usuario', maxWidth: '760px', content: document.getElementById('userFormTemplate').innerHTML });
        bindUserForm(user);
    };
    window.editUser = id => openUserModal(id);
    window.toggleUser = async id => {
        await store.users.toggle(id);
        app.toast.success('Estado actualizado.');
        renderUsers();
    };

    document.getElementById('openUserQuickActions').addEventListener('click', () => openUserModal());
    search.addEventListener('input', renderUsers);
    store.refresh().then(() => { renderRoles(); renderUsers(); }).catch(error => app.toast.error(error.message));
})();
</script>
}
