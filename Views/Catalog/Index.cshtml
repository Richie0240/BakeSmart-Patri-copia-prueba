@model BakeSmartPatri.Models.CatalogIndexViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Catalogo de Productos";
    var culture = new System.Globalization.CultureInfo("es-CR");
}

<div class="page-header" style="margin: 2rem 0 2.5rem 1.5rem;">
    <div>
        <div style="display: flex; align-items: center; gap: 0.75rem;">
            <div style="width: 5px; height: 50px; background: var(--gradient-primary); border-radius: 5px;"></div>
            <div>
                <h1 style="margin: 0; font-size: 2.5rem; display: flex; align-items: center; gap: 0.75rem;">
                    <i class="fas fa-book-open" style="color: var(--primary);"></i>
                    Nuestro Catalogo
                </h1>
                <p class="text-muted" style="margin-top: 0.5rem; font-size: 1rem; max-width: 600px;">
                    Descubre nuestra seleccion de productos artesanales, preparados con los mejores ingredientes y mucho amor
                </p>
            </div>
        </div>
    </div>
    <div style="display: flex; gap: 1rem; margin-right: 1.5rem;">
        <span class="badge badge-primary" style="font-size: 0.9rem; padding: 0.5rem 1rem;">
            <i class="fas fa-box-open"></i>
            @DateTime.Now.ToString("dddd, dd MMM", new System.Globalization.CultureInfo("es-ES"))
        </span>
    </div>
</div>

<div style="padding: 0 1.5rem;">
    <div class="catalog-toolbar">
        <div class="catalog-search-row" style="display: flex; gap: 0.5rem;">
            <div class="catalog-search-field" style="flex: 1; position: relative;">
                <i class="fas fa-search" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
                <input type="text" class="input" id="searchProduct" placeholder="Buscar productos por nombre..." style="padding-left: 2.5rem;">
            </div>
            <button class="btn btn-primary catalog-search-button" type="button" onclick="filterProducts()">
                <i class="fas fa-search"></i>
            </button>
            <button class="btn btn-outline catalog-categories-trigger" type="button" id="openCategoriesSidebar">
                <i class="fas fa-layer-group"></i>
                Categorias
            </button>
        </div>
        <div class="catalog-active-filter" id="catalogActiveFilter">
            <i class="fas fa-filter"></i>
            <span>Todas las categorias</span>
        </div>
    </div>

    <div class="grid grid-3" id="productsGrid" style="gap: clamp(1rem, 1.8vw, 2rem);">
        @foreach (var product in Model.Products)
        {
            <div class="card product-card" data-id="@product.Id" data-category="@product.Category" data-price="@product.UnitPrice" data-name="@product.Name">
                <div style="position: relative;">
                    <img src="@product.ImageUrl"
                         alt="@product.AltText"
                         onerror="this.src='/img/products/producto-sin-imagen.svg';"
                         style="width: 100%; height: 250px; object-fit: cover; border-radius: var(--radius);">
                    <span class="badge badge-primary" style="position: absolute; top: 1rem; right: 1rem;">@product.Category</span>
                    <button class="btn btn-ghost btn-sm favorite-btn" style="position: absolute; top: 1rem; left: 1rem; background: white; border-radius: 50%; width: 40px; height: 40px;" onclick="toggleFavorite(this)">
                        <i class="far fa-heart"></i>
                    </button>
                </div>

                <div style="margin-top: 1rem;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.5rem; gap: .75rem;">
                        <h3 style="margin: 0; font-size: clamp(1.05rem, 1.4vw, 1.25rem); line-height: 1.25;">@product.Name</h3>
                        <div style="display: flex; gap: 0.25rem; color: #fbbf24; flex-shrink: 0;">
                            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                        </div>
                    </div>

                    <p class="text-muted" style="margin-bottom: 1rem;">
                        @product.Description
                    </p>

                    <div style="display: flex; gap: 0.5rem; margin-bottom: 1rem; flex-wrap: wrap;">
                        <span class="badge"><i class="fas fa-barcode"></i> @product.Code</span>
                        <span class="badge"><i class="fas fa-box"></i> @product.Stock.ToString("0.##") @product.Unit</span>
                        @if (!string.IsNullOrWhiteSpace(product.Subcategory))
                        {
                            <span class="badge badge-info">@product.Subcategory</span>
                        }
                    </div>

                    <div style="display: flex; justify-content: space-between; align-items: center; gap: 0.5rem;">
                        <span style="font-weight: 700; font-size: 1.5rem; color: var(--primary);">@product.UnitPrice.ToString("C0", culture)</span>
                        <div style="display: flex; gap: 0.5rem;">
                            <a href="/Catalog/Details/@product.Id" class="btn btn-outline btn-sm" title="Ver detalles">
                                <i class="fas fa-eye"></i>
                            </a>
                            <button class="btn btn-primary btn-sm" type="button"
                                    data-id="@product.Id"
                                    data-name="@product.Name"
                                    data-price="@product.UnitPrice.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                    onclick="addProductButton(this)">
                                <i class="fas fa-shopping-cart"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="catalog-categories-backdrop" id="catalogCategoriesBackdrop" hidden></div>
<aside class="catalog-categories-sidebar" id="catalogCategoriesSidebar" aria-hidden="true" aria-labelledby="catalogCategoriesTitle">
    <div class="catalog-categories-sidebar__header">
        <div>
            <span>Catalogo</span>
            <h2 id="catalogCategoriesTitle">Categorias</h2>
        </div>
        <button class="catalog-sidebar-close" type="button" id="closeCategoriesSidebar" aria-label="Cerrar categorias">
            <i class="fas fa-xmark"></i>
        </button>
    </div>

    <div class="catalog-categories-sidebar__body">
        <button class="catalog-category-option category-btn active" data-category="all" type="button">
            <span><i class="fas fa-th-large"></i></span>
            <strong>Todas las categorias</strong>
            <small>@Model.Products.Count productos</small>
        </button>
        @foreach (var category in Model.Categories)
        {
            var count = Model.Products.Count(product => product.Category == category.Name);
            <button class="catalog-category-option category-btn" data-category="@category.Name" type="button">
                <span><i class="fas @category.Icon"></i></span>
                <strong>@category.Name</strong>
                <small>@count productos</small>
            </button>
        }
    </div>
</aside>

<!-- Mobile cart backdrop -->
<div class="mobile-sheet-backdrop" id="catalogCartBackdrop" style="display:none;"></div>

<button type="button" id="catalogCartButton" class="btn btn-primary" style="display:none;position:fixed;right:1.25rem;bottom:1.25rem;z-index:5200;width:64px;height:64px;border-radius:50%;box-shadow:0 22px 54px rgba(139,92,246,.35);padding:0!important;" aria-label="Abrir carrito">
    <i class="fas fa-shopping-cart"></i>
    <span id="catalogCartButtonCount" style="position:absolute;top:-6px;right:-6px;min-width:26px;height:26px;border-radius:999px;background:#fff;color:var(--primary-dark);font-weight:900;font-size:.78rem;display:inline-flex;align-items:center;justify-content:center;border:1px solid var(--border);">0</span>
</button>

<!-- Mobile bottom-sheet cart -->
<div class="mobile-bottom-sheet" id="catalogCartSheet" role="dialog" aria-modal="true" aria-hidden="true" style="display:none;">
    <div class="mobile-bottom-sheet-header">
        <h3><i class="fas fa-shopping-cart" style="color:var(--primary);margin-right:.5rem;"></i>Carrito</h3>
        <button class="btn btn-ghost btn-sm" type="button" id="catalogCartClose" aria-label="Cerrar carrito" style="width:40px;height:40px;padding:0!important;border-radius:50%!important;">
            <i class="fas fa-xmark"></i>
        </button>
    </div>

    <span class="badge badge-primary" id="cartCount" style="margin-bottom:.75rem;">0</span>

    <div id="cartItems" style="max-height:60vh;overflow-y:auto;margin-bottom:.75rem;"></div>

    <div style="display:flex;justify-content:space-between;font-weight:700;padding:.75rem 0;border-top:1px solid var(--border);margin-bottom:.75rem;">
        <span>Total:</span>
        <span id="cartTotal" style="color:var(--primary);font-size:1.15rem;">₡0</span>
    </div>

    <a href="/Orders/Create" class="btn btn-primary btn-block" style="min-height:50px;">
        <i class="fas fa-arrow-right"></i>
        Finalizar pedido
    </a>
</div>

<!-- Desktop cart floating card -->
<div class="card" style="position: fixed; bottom: 20px; right: 20px; width: 320px; display: none; box-shadow: var(--shadow-xl); z-index: 1000; border-radius: 18px;" id="cartSummary">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
        <h4 style="margin: 0; display: flex; align-items: center; gap: 0.5rem;">
            <i class="fas fa-shopping-cart" style="color: var(--primary);"></i>
            Carrito
        </h4>
        <span class="badge badge-primary" id="cartCountDesktop">0</span>
    </div>
    <div id="cartItemsDesktop" style="max-height: 200px; overflow-y: auto; margin-bottom: 0.5rem;"></div>
    <div style="display: flex; justify-content: space-between; font-weight: 700; margin-bottom: 0.5rem;">
        <span>Total:</span>
        <span id="cartTotalDesktop" style="color:var(--primary);">₡0</span>
    </div>
    <a href="/Orders/Create" class="btn btn-primary btn-block">
        <i class="fas fa-arrow-right"></i>
        Finalizar pedido
    </a>
</div>

<script>
    let currentCategory = 'all';
    let cart = [];
    let shouldAutoOpenCart = false;

    function filterCategory(category) {
        currentCategory = category;
        const buttons = document.querySelectorAll('.category-btn');
        buttons.forEach(btn => {
            const active = btn.dataset.category === category || (category === 'all' && btn.dataset.category === 'all');
            btn.classList.toggle('btn-primary', active);
            btn.classList.toggle('btn-outline', !active);
            btn.classList.toggle('active', active);
        });
        const activeLabel = category === 'all' ? 'Todas las categorias' : category;
        document.querySelector('#catalogActiveFilter span').textContent = activeLabel;
        filterProducts();
    }

    function filterProducts() {
        const searchTerm = document.getElementById('searchProduct').value.toLowerCase();
        document.querySelectorAll('.product-card').forEach(product => {
            const matchesCategory = currentCategory === 'all' || product.dataset.category === currentCategory;
            const matchesSearch = !searchTerm || product.dataset.name.toLowerCase().includes(searchTerm);
            product.style.display = matchesCategory && matchesSearch ? 'block' : 'none';
        });
    }

    document.getElementById('searchProduct').addEventListener('input', app.utils.debounce(filterProducts, 250));

    function openCategoriesSidebar() {
        const sidebar = document.getElementById('catalogCategoriesSidebar');
        const backdrop = document.getElementById('catalogCategoriesBackdrop');
        sidebar.classList.add('is-open');
        sidebar.setAttribute('aria-hidden', 'false');
        backdrop.hidden = false;
        document.body.classList.add('catalog-sidebar-open');
    }

    function closeCategoriesSidebar() {
        const sidebar = document.getElementById('catalogCategoriesSidebar');
        const backdrop = document.getElementById('catalogCategoriesBackdrop');
        sidebar.classList.remove('is-open');
        sidebar.setAttribute('aria-hidden', 'true');
        backdrop.hidden = true;
        document.body.classList.remove('catalog-sidebar-open');
    }

    document.getElementById('openCategoriesSidebar').addEventListener('click', openCategoriesSidebar);
    document.getElementById('closeCategoriesSidebar').addEventListener('click', closeCategoriesSidebar);
    document.getElementById('catalogCategoriesBackdrop').addEventListener('click', closeCategoriesSidebar);
    document.getElementById('catalogCategoriesSidebar').addEventListener('click', event => {
        const button = event.target.closest('[data-category]');
        if (!button) return;
        filterCategory(button.dataset.category);
        closeCategoriesSidebar();
    });
    document.addEventListener('keydown', event => {
        if (event.key === 'Escape') closeCategoriesSidebar();
    });

    function toggleFavorite(btn) {
        const icon = btn.querySelector('i');
        icon.classList.toggle('far');
        icon.classList.toggle('fas');
        if (icon.classList.contains('fas')) {
            icon.style.color = '#ec4899';
            app.toast.show('Agregado a favoritos', 'success');
        } else {
            icon.style.color = '';
        }
    }

    function addProductButton(button) {
        addToCart(Number(button.dataset.id), button.dataset.name, Number(button.dataset.price));
    }

    function addToCart(productId, name, price) {
        const existingItem = cart.find(item => item.id === productId);
        if (existingItem) {
            existingItem.quantity++;
        } else {
            cart.push({ id: productId, name, price, quantity: 1 });
        }

        updateCartDisplay();
        app.toast.show(`${name} agregado al carrito`, 'success');
    }

    function removeFromCart(productId) {
        cart = cart.filter(item => item.id !== productId);
        updateCartDisplay();
    }

    function openCartSheet() {
        const sheet = document.getElementById('catalogCartSheet');
        const backdrop = document.getElementById('catalogCartBackdrop');
        if (sheet) {
            sheet.style.display = 'block';
            sheet.classList.add('open');
            sheet.setAttribute('aria-hidden', 'false');
        }
        if (backdrop) {
            backdrop.style.display = 'block';
            backdrop.classList.add('open');
        }
    }

    function closeCartSheet() {
        const sheet = document.getElementById('catalogCartSheet');
        const backdrop = document.getElementById('catalogCartBackdrop');
        if (sheet) {
            sheet.classList.remove('open');
            sheet.setAttribute('aria-hidden', 'true');
            sheet.style.display = 'none';
        }
        if (backdrop) {
            backdrop.classList.remove('open');
            backdrop.style.display = 'none';
        }
    }

    document.getElementById('catalogCartClose').addEventListener('click', closeCartSheet);
    document.getElementById('catalogCartBackdrop').addEventListener('click', closeCartSheet);
    document.getElementById('catalogCartButton').addEventListener('click', openCartSheet);

    function updateCartDisplay() {
        const cartSummary = document.getElementById('cartSummary');
        const cartItems = document.getElementById('cartItems');
        const cartItemsDesktop = document.getElementById('cartItemsDesktop');
        const cartCount = document.getElementById('cartCount');
        const cartCountDesktop = document.getElementById('cartCountDesktop');
        const cartTotal = document.getElementById('cartTotal');
        const cartTotalDesktop = document.getElementById('cartTotalDesktop');
        const cartButton = document.getElementById('catalogCartButton');
        const cartButtonCount = document.getElementById('catalogCartButtonCount');
        const total = cart.reduce((sum, item) => sum + item.price * item.quantity, 0);
        const count = cart.reduce((sum, item) => sum + item.quantity, 0);

        const cartHtml = cart.map(item => `
            <div style="display:flex;justify-content:space-between;align-items:center;gap:.5rem;margin-bottom:.5rem;padding:.65rem;border-radius:12px;border:1px solid var(--border);background:var(--bg-alt);">
                <div style="min-width:0;flex:1;">
                    <strong style="display:block;font-size:.9rem;">${item.name}</strong>
                    <span class="text-muted" style="font-size:.78rem;">Cant: ${item.quantity} × ₡${item.price.toLocaleString('es-CR')}</span>
                </div>
                <div style="display:flex;align-items:center;gap:.5rem;flex-shrink:0;">
                    <span style="font-weight:700;white-space:nowrap;">₡${(item.price * item.quantity).toLocaleString('es-CR')}</span>
                    <button class="btn btn-ghost btn-sm" onclick="removeFromCart(${item.id})" style="color:var(--danger);width:36px;height:36px;padding:0!important;border-radius:50%!important;">
                        <i class="fas fa-trash-can"></i>
                    </button>
                </div>
            </div>
        `).join('') || '<div class="text-muted" style="padding:.5rem 0;">Carrito vacío</div>';

        cartSummary.style.display = 'none';
        cartButton.style.display = cart.length ? 'inline-flex' : 'none';
        cartCount.textContent = count;
        cartButtonCount.textContent = count;
        if (cartCountDesktop) cartCountDesktop.textContent = count;
        cartTotal.textContent = `₡${total.toLocaleString('es-CR')}`;
        if (cartTotalDesktop) cartTotalDesktop.textContent = `₡${total.toLocaleString('es-CR')}`;
        cartItems.innerHTML = cartHtml;
        if (cartItemsDesktop) cartItemsDesktop.innerHTML = cartHtml;

        shouldAutoOpenCart = false;
    }

    document.addEventListener('DOMContentLoaded', () => {
        const parameters = new URLSearchParams(window.location.search);
        const search = parameters.get('search');
        const category = parameters.get('category');
        const categoriesOpen = parameters.get('categories') === 'open';
        const productId = Number(parameters.get('add'));

        if (search) {
            document.getElementById('searchProduct').value = search;
            filterProducts();
        }

        if (category) {
            const categoryButton = Array.from(document.querySelectorAll('.category-btn'))
                .find(button => button.dataset.category.toLowerCase() === category.toLowerCase());
            if (categoryButton) filterCategory(categoryButton.dataset.category);
        }

        if (categoriesOpen) {
            openCategoriesSidebar();
        }

        if (productId) {
            const addButton = document.querySelector(`[data-id="${productId}"][data-name][data-price]`);
            if (addButton) {
                addProductButton(addButton);
                openCartSheet();
            }
        } else if (parameters.get('cart') === 'open' && cart.length) {
            openCartSheet();
        }
    });
</script>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/catalog-index.css" asp-append-version="true" />
}
