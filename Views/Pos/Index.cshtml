
@section Styles {
    <link rel="stylesheet" href="~/css/pages/pos-index.css" asp-append-version="true" />
    <style>
        #posCartPanel:not(.pos-cart-open) {
            position: fixed !important;
            opacity: 0 !important;
            visibility: hidden !important;
            pointer-events: none !important;
            transform: translateX(28px) scale(.98) !important;
        }

        #posCartPanel.pos-cart-open {
            visibility: visible !important;
        }

        body.pos-cart-is-open #posCartToggle {
            opacity: 0 !important;
            pointer-events: none !important;
        }
    </style>
}
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Punto de venta";
    var canManagePayments = User.IsInRole("Admin") || User.IsInRole("Staff");
    var canViewCashSessions = User.IsInRole("Admin") || User.IsInRole("Staff") || User.IsInRole("Supervisor");
    var canManageCreditNotes = User.IsInRole("Admin") || User.IsInRole("Staff");
}

<div class="page-shell pos-page">
    <div class="page-header pos-header">
        <div>
            <h1 class="pos-title">
                <i class="fas fa-cash-register"></i>
                Punto de venta
            </h1>
            <p class="text-muted pos-subtitle">
                Apertura y cierre de caja, búsqueda de productos, carrito y confirmación de venta.
            </p>
        </div>

        <div class="pos-search-box">
            <input id="posSearch" class="form-control" placeholder="Buscar por código o nombre" />
        </div>
    </div>

    <div class="grid grid-4 pos-summary-grid">
        <div class="card pos-summary-card">
            <span class="text-muted">Caja activa</span>
            <h2 id="posSessionStatus"></h2>
        </div>

        <div class="card pos-summary-card">
            <span class="text-muted">Ventas del turno</span>
            <h2 id="posSessionSales"></h2>
        </div>

        <div class="card pos-summary-card">
            <span class="text-muted">Productos disponibles</span>
            <h2 id="posProductsCount"></h2>
        </div>

        <div class="card pos-summary-card">
            <span class="text-muted">Métodos de pago activos</span>
            <h2 id="posMethodsCount"></h2>
        </div>
    </div>

    <div class="pos-layout">
        <aside class="card pos-side-card">
            <section class="pos-admin-block pos-admin-block--cash">
                <div class="pos-panel-header">
                    <div>
                        <div class="pos-panel-eyebrow">Caja</div>
                        <h3 class="pos-panel-title">Control de caja</h3>
                    </div>
                    <span class="status-chip pos-box-chip" id="posBoxChip">Sin turno</span>
                </div>

                <div id="posSessionPanel"></div>
            </section>

            <section class="pos-admin-block pos-admin-block--sessions">
                <div class="pos-sessions-board" id="posSessionsBoard">
                    <div class="pos-panel-header pos-panel-header--compact">
                        <div>
                            <div class="pos-panel-eyebrow">Supervision</div>
                            <h4 class="pos-panel-title-sm">Estado de cajas</h4>
                        </div>
                    </div>
                    <div id="posSessionsList" class="pos-sessions-list"></div>
                </div>
            </section>

            <section class="pos-admin-block pos-admin-block--payments">
                <div class="pos-panel-header pos-panel-header--compact">
                    <div>
                        <div class="pos-panel-eyebrow">Cobro</div>
                        <h4 class="pos-panel-title-sm">Formas de pago</h4>
                    </div>
                </div>

                <div id="paymentMethodsPanel" class="payment-methods-panel"></div>

                <form id="paymentMethodForm" class="pos-payment-config-form" hidden="@(!canManagePayments)">
                    <input class="form-control" name="name" placeholder="Forma de pago" required />
                    <input class="form-control" name="commissionRate" type="number" min="0" step="0.01" placeholder="Comisión" required />
                    <input class="form-control" name="account" placeholder="Cuenta contable" required />
                    <button class="btn btn-outline btn-sm" type="submit">Guardar forma</button>
                </form>
            </section>

            <section class="pos-admin-block pos-admin-block--credit" hidden="@(!canManageCreditNotes)">
                <form id="creditNoteForm" class="pos-payment-config-form">
                    <input class="form-control" name="saleId" type="number" min="1" placeholder="ID de venta o pedido" required />
                    <input class="form-control" name="reason" placeholder="Motivo de nota de crédito" required />
                    <button class="btn btn-ghost btn-sm" type="submit">Registrar nota</button>
                </form>
                <div class="pos-recent-sales" id="posRecentSales"></div>
            </section>
        </aside>

        <section class="card pos-main-card">
            <div class="pos-main-grid">
                <section class="pos-products-section">
                    <div class="pos-panel-header">
                        <div>
                            <div class="pos-panel-eyebrow">Inventario de venta</div>
                            <h3 class="pos-panel-title">Productos</h3>
                        </div>
                        <span class="badge badge-primary">
                            <span id="posProductsBadgeCount">0</span>&nbsp;items
                        </span>
                    </div>

                    <div class="pos-products-grid" id="posProductsGrid"></div>

                    <div class="table-container pos-products-table-wrapper">
                        <table class="table pos-products-table">
                            <thead>
                                <tr>
                                    <th>Código</th>
                                    <th>Producto</th>
                                    <th>Precio</th>
                                    <th>Stock</th>
                                    <th class="text-right">Acción</th>
                                </tr>
                            </thead>
                            <tbody id="posProductsTable"></tbody>
                        </table>
                    </div>
                </section>

                <button class="pos-cart-fab" type="button" id="posCartToggle" aria-label="Abrir carrito">
                    <i class="fas fa-cart-shopping"></i>
                    <span id="posCartFabCount">0</span>
                </button>

                <!-- Mobile cart backdrop -->
                <div class="mobile-sheet-backdrop" id="posCartBackdrop" style="display:none;"></div>

                <!-- Mobile bottom-sheet cart overlay -->
                <div class="mobile-bottom-sheet" id="posCartSheet" role="dialog" aria-modal="true" aria-hidden="true" style="display:none;">
                    <div class="mobile-bottom-sheet-header">
                        <h3><i class="fas fa-cart-shopping" style="color:var(--primary);margin-right:.5rem;"></i>Carrito actual</h3>
                        <button class="btn btn-ghost btn-sm" type="button" id="posCartSheetClose" aria-label="Cerrar carrito" style="width:40px;height:40px;padding:0!important;border-radius:50%!important;">
                            <i class="fas fa-xmark"></i>
                        </button>
                    </div>

                    <div id="posCartItemsBadge" style="margin-bottom:.75rem;">
                        <span class="badge badge-info">0 productos</span>
                    </div>

                    <div id="posCart" class="pos-cart-list" style="margin-bottom:1rem;"></div>

                    <form id="posCheckoutForm" class="pos-checkout-form">
                        <div class="pos-form-block">
                            <label>Cliente</label>
                            <input class="form-control pos-customer-input" name="customerName" list="posCustomerOptions" placeholder="Buscar cliente o escribir manualmente" />
                        </div>

                        <div class="pos-form-block">
                            <label>Correo</label>
                            <input class="form-control" name="customerEmail" placeholder="correo@cliente.com" />
                        </div>

                        <div class="pos-form-block">
                            <label>Teléfono</label>
                            <input class="form-control" name="customerPhone" placeholder="Teléfono" />
                        </div>

                        <div class="pos-form-block">
                            <label>Método de pago</label>
                            <select class="form-control" name="paymentMethod" id="posPaymentMethod"></select>
                        </div>

                        <div class="pos-form-block">
                            <label>Descuento</label>
                            <input class="form-control" type="number" min="0" step="0.01" name="discountRate" value="0" placeholder="Ej. 0.05" />
                        </div>

                        <button class="btn btn-primary pos-submit-btn" type="submit" style="min-height:52px;">
                            <i class="fas fa-check-circle"></i>
                            Confirmar venta
                        </button>
                    </form>
                </div>

                <!-- Desktop cart mini summary -->
                <section class="pos-cart-section pos-cart-summary-panel" id="posCartPanel" aria-hidden="true" style="display:none;position:fixed;top:auto;right:24px;left:auto;bottom:96px;z-index:5300;width:min(420px,calc(100vw - 2rem));max-height:min(70vh,560px);overflow:auto;transform:translateX(28px) scale(.98);">
                    <div class="pos-panel-header">
                        <div>
                            <div class="pos-panel-eyebrow">Resumen</div>
                            <h3 class="pos-panel-title"><i class="fas fa-cart-shopping"></i> Carrito</h3>
                        </div>
                        <div class="pos-cart-panel-actions">
                            <span class="badge badge-info" id="posCartItemsBadgeDesktop">0 productos</span>
                            <button class="btn btn-outline btn-sm pos-cart-close" type="button" id="posCartClose" aria-label="Cerrar carrito">
                                <i class="fas fa-xmark"></i>
                            </button>
                        </div>
                    </div>

                    <div id="posCartDesktop" class="pos-cart-list"></div>

                    <div class="pos-cart-summary-actions">
                        <button class="btn btn-outline" type="button" onclick="closeCartPanel()">Seguir vendiendo</button>
                        <button class="btn btn-primary" type="button" onclick="continueToCart()">
                            Continuar
                            <i class="fas fa-arrow-right"></i>
                        </button>
                    </div>

                    <form id="posCheckoutFormDesktop" class="pos-checkout-form" style="display:none;">
                        <div class="pos-form-block">
                            <label>Cliente</label>
                            <input class="form-control pos-customer-input" name="customerName" list="posCustomerOptions" placeholder="Buscar cliente o escribir manualmente" />
                        </div>

                        <div class="pos-form-block">
                            <label>Correo</label>
                            <input class="form-control" name="customerEmail" placeholder="correo@cliente.com" />
                        </div>

                        <div class="pos-form-block">
                            <label>Teléfono</label>
                            <input class="form-control" name="customerPhone" placeholder="Teléfono" />
                        </div>

                        <div class="pos-form-block">
                            <label>Método de pago</label>
                            <select class="form-control" name="paymentMethod" id="posPaymentMethodDesktop"></select>
                        </div>

                        <div class="pos-form-block">
                            <label>Descuento adicional</label>
                            <input class="form-control" type="number" min="0" step="0.01" name="discountRate" value="0" placeholder="Ej. 0.05" />
                        </div>

                        <button class="btn btn-primary pos-submit-btn" type="submit">
                            <i class="fas fa-check-circle"></i>
                            Confirmar venta
                        </button>
                    </form>
                </section>
                <datalist id="posCustomerOptions"></datalist>
            </div>
        </section>
    </div>

</div>



@section Scripts {
    <script>
        (() => {
            const store = BakeSmartStore;
            const searchInput = document.getElementById('posSearch');
            const checkoutForm = document.getElementById('posCheckoutForm');
            const cart = [];
            const fmt = app.utils.formatCurrency;
            let recentSales = [];
            const permissions = {
                canManagePayments: @canManagePayments.ToString().ToLowerInvariant(),
                canViewCashSessions: @canViewCashSessions.ToString().ToLowerInvariant(),
                canManageCreditNotes: @canManageCreditNotes.ToString().ToLowerInvariant()
            };

            const getConfig = () => store.pos.config();
            const getActiveSession = () => store.pos.activeSession();
            const getProducts = () => store.pos.searchProducts(searchInput.value);
            const money = value => app.utils.formatCurrency(Number(value || 0));

            ['posCartToggle', 'posCartBackdrop', 'posCartSheet', 'posCartPanel'].forEach(id => {
                const element = document.getElementById(id);
                if (element && element.parentElement !== document.body) {
                    document.body.appendChild(element);
                }
            });

            function renderSummary() {
                const session = getActiveSession();
                const products = getProducts();
                const methods = getConfig().paymentMethods.filter(x => x.active);

                document.getElementById('posSessionStatus').textContent = session ? `#${String(session.id).slice(-6)}` : 'Sin abrir';
                document.getElementById('posSessionSales').textContent = fmt(session?.totalSales || 0);
                document.getElementById('posProductsCount').textContent = products.length;
                document.getElementById('posMethodsCount').textContent = methods.length;
                document.getElementById('posProductsBadgeCount').textContent = products.length;

                const boxChip = document.getElementById('posBoxChip');
                boxChip.textContent = session ? 'Turno activo' : 'Sin turno';
            }

            function renderSessionPanel() {
                const session = getActiveSession();
                const container = document.getElementById('posSessionPanel');
                document.getElementById('posSessionsBoard')?.toggleAttribute('hidden', !permissions.canViewCashSessions);
                document.getElementById('paymentMethodForm')?.toggleAttribute('hidden', !permissions.canManagePayments);
                document.getElementById('creditNoteForm')?.toggleAttribute('hidden', !permissions.canManageCreditNotes);
                document.getElementById('posRecentSales')?.toggleAttribute('hidden', !permissions.canManageCreditNotes);

                if (session) {
                    container.innerHTML = `
                        <div class="session-status-card">
                            <div class="session-status-title">Responsable</div>
                            <div class="session-status-value">${session.userName}</div>
                            <div class="text-muted" style="margin-top:.35rem;">Apertura: ${new Date(session.openedAt).toLocaleString('es-CR')}</div>

                            <div class="session-inline-actions">
                                <input id="declaredCash" class="form-control" type="number" min="0" placeholder="Efectivo contado" />
                                <button class="btn btn-outline" type="button" onclick="closeSession()">Cerrar caja</button>
                            </div>
                        </div>
                    `;
                } else {
                    container.innerHTML = `
                        <div class="session-status-card">
                            <div class="session-status-title">Estado actual</div>
                            <div class="session-status-value">No hay turno abierto</div>

                            <div class="session-inline-actions">
                                <input id="openingAmount" class="form-control" type="number" min="0" placeholder="Monto apertura" />
                                <button class="btn btn-primary" type="button" onclick="openSession()">Abrir caja</button>
                            </div>
                        </div>
                    `;
                }

                renderPaymentMethods();
                if (permissions.canViewCashSessions) renderSessionsList();
                if (permissions.canManageCreditNotes) renderRecentSales();
            }

            function renderSessionsList() {
                const container = document.getElementById('posSessionsList');
                const sessions = store.pos.cachedSessions ? store.pos.cachedSessions() : [];
                container.innerHTML = sessions.slice(0, 5).map(session => `
                    <article class="pos-session-row">
                        <div>
                            <strong>Caja #${session.id}</strong>
                            <span>${session.userName || 'Sistema'} · ${new Date(session.openedAt).toLocaleString('es-CR')}</span>
                        </div>
                        <div>
                            <span class="badge ${String(session.status || '').toLowerCase().startsWith('abiert') ? 'badge-success' : 'badge-warning'}">${session.status}</span>
                            <b>${money(session.totalSales)}</b>
                        </div>
                    </article>
                `).join('') || '<div class="text-muted pos-small-empty">No hay cajas registradas.</div>';
            }

            function renderRecentSales() {
                const container = document.getElementById('posRecentSales');
                container.innerHTML = `
                    <div class="pos-panel-header pos-panel-header--compact">
                        <div>
                            <div class="pos-panel-eyebrow">Notas de credito</div>
                            <h4 class="pos-panel-title-sm">Ventas recientes</h4>
                        </div>
                    </div>
                    <div class="pos-sales-list">
                        ${recentSales.slice(0, 6).map(sale => `
                            <button class="pos-sale-row" type="button" onclick="selectCreditNoteSale(${sale.saleId})" ${sale.hasCreditNote ? 'disabled' : ''}>
                                <span>
                                    <strong>Venta #${sale.saleId}</strong>
                                    <small>Pedido #${sale.orderId} · ${sale.customerName}</small>
                                </span>
                                <b>${money(sale.total)}</b>
                            </button>
                        `).join('') || '<div class="text-muted pos-small-empty">Aun no hay ventas POS.</div>'}
                    </div>
                `;
            }

            function renderPaymentMethods() {
                const methods = getConfig().paymentMethods;
                const paymentPanel = document.getElementById('paymentMethodsPanel');
                const paymentSelect = document.getElementById('posPaymentMethod');
                const paymentSelectDesktop = document.getElementById('posPaymentMethodDesktop');

                paymentPanel.innerHTML = methods.map(method => `
                    <div class="payment-method-card">
                        <div class="payment-method-row payment-method-row-between">
                                <div>
                                    <div class="payment-method-name">${method.name}</div>
                                    <div class="payment-method-account">Cuenta: ${method.account} · Comisión: ${Number(method.commissionRate || 0).toFixed(2)}</div>
                                </div>
                            ${permissions.canManagePayments
                                ? `<button class="badge ${method.active ? 'badge-success' : 'badge-warning'}" type="button" onclick="togglePaymentMethod(${method.id})">${method.active ? 'Activo' : 'Inactivo'}</button>`
                                : `<span class="badge ${method.active ? 'badge-success' : 'badge-warning'}">${method.active ? 'Activo' : 'Inactivo'}</span>`}
                        </div>
                    </div>
                `).join('');

                const activeMethods = methods
                    .filter(method => method.active)
                    .map(method => `<option value="${method.name}">${method.name}</option>`)
                    .join('');

                if (paymentSelect) paymentSelect.innerHTML = activeMethods;
                if (paymentSelectDesktop) paymentSelectDesktop.innerHTML = activeMethods;
            }

            function renderCustomerOptions() {
                const options = document.getElementById('posCustomerOptions');
                if (!options) return;

                options.innerHTML = store.customers.list().map(customer => `
                    <option value="${customer.fullName || customer.name || ''}" data-email="${customer.email || ''}" data-phone="${customer.phone || ''}">
                        ${customer.email || customer.phone || 'Cliente registrado'}
                    </option>
                `).join('');
            }

            function applyCustomerSelection(input) {
                const selected = store.customers.list().find(customer =>
                    String(customer.fullName || customer.name || '').toLowerCase() === String(input.value || '').toLowerCase()
                );

                if (!selected) return;

                const form = input.closest('form');
                if (!form) return;

                const emailInput = form.querySelector('[name="customerEmail"]');
                const phoneInput = form.querySelector('[name="customerPhone"]');
                if (emailInput) emailInput.value = selected.email || '';
                if (phoneInput) phoneInput.value = selected.phone || '';
            }

            function renderProducts() {
                const products = getProducts();
                const tableBody = document.getElementById('posProductsTable');
                const productsGrid = document.getElementById('posProductsGrid');

                if (!products.length) {
                    productsGrid.innerHTML = `<div class="card pos-empty-products">No se encontraron productos.</div>`;
                    tableBody.innerHTML = `
                        <tr>
                            <td colspan="5" class="text-center text-muted">No se encontraron productos.</td>
                        </tr>
                    `;
                    return;
                }

                productsGrid.innerHTML = products.map(product => {
                    const availableStock = remainingStock(product.id, product.stock);
                    const stockPct = Math.min(100, Math.round((availableStock / Math.max(product.stock, 20)) * 100));
                    const stockColor = stockPct > 50 ? 'var(--success)' : stockPct > 20 ? 'var(--warning)' : 'var(--danger)';
                    const disabled = availableStock <= 0 ? 'disabled' : '';
                    return `
                    <article class="pos-product-card">
                        <div class="pos-product-top">
                            <span class="pos-product-code">${product.code}</span>
                            <h4>${product.description}</h4>
                        </div>
                        <div class="pos-product-price-tag">
                            <span>${fmt(product.price)}</span>
                            <small>c/u</small>
                        </div>
                        <div class="pos-product-stock-bar">
                            <div class="stock-track">
                                <div class="stock-fill" style="width:${stockPct}%;background:${stockColor};"></div>
                            </div>
                            <span class="stock-label">${availableStock} disp. de ${product.stock}</span>
                        </div>
                        <button class="pos-product-cart-btn" type="button" onclick="addToCart(${product.id})" ${disabled}>
                            <i class="fas fa-cart-plus"></i>
                            ${availableStock > 0 ? 'Agregar' : 'Sin stock'}
                        </button>
                    </article>
                `}).join('');

                tableBody.innerHTML = products.map(product => `
                    <tr>
                        <td>${product.code}</td>
                        <td>${product.description}</td>
                        <td>${fmt(product.price)}</td>
                        <td>${remainingStock(product.id, product.stock)} / ${product.stock}</td>
                        <td class="text-right">
                            <button class="btn btn-outline btn-sm" type="button" onclick="addToCart(${product.id})" ${remainingStock(product.id, product.stock) <= 0 ? 'disabled' : ''}>
                                Agregar
                            </button>
                        </td>
                    </tr>
                `).join('');
            }

            function cartQuantity(productId) {
                return cart
                    .filter(item => Number(item.productId) === Number(productId))
                    .reduce((sum, item) => sum + Number(item.quantity || 0), 0);
            }

            function remainingStock(productId, stock) {
                return Math.max(0, Number(stock || 0) - cartQuantity(productId));
            }

            function renderCart() {
                const cartContainer = document.getElementById('posCart');
                const cartContainerDesktop = document.getElementById('posCartDesktop');
                document.getElementById('posCartItemsBadge').textContent = `${cart.length} producto${cart.length === 1 ? '' : 's'}`;
                const desktopBadge = document.getElementById('posCartItemsBadgeDesktop');
                if (desktopBadge) desktopBadge.textContent = `${cart.length} producto${cart.length === 1 ? '' : 's'}`;
                document.getElementById('posCartFabCount').textContent = cart.length;

                const cartHtml = buildCartHtml();
                cartContainer.innerHTML = cartHtml;
                if (cartContainerDesktop) cartContainerDesktop.innerHTML = buildCartSummaryHtml();
                saveCartSnapshot();
                renderProducts();
                renderSummary();
            }

            function saveCartSnapshot() {
                sessionStorage.setItem('bakesmart.pos.cart', JSON.stringify(cart));
            }

            window.continueToCart = () => {
                saveCartSnapshot();
                window.location.assign('/Pos/Cart');
            };

            function buildCartSummaryHtml() {
                if (!cart.length) {
                    return `
                        <div class="pos-cart-mini-empty">
                            <i class="fas fa-basket-shopping"></i>
                            <strong>Carrito vacio</strong>
                            <span>Agregue productos para continuar.</span>
                        </div>
                    `;
                }

                const subtotal = cart.reduce((acc, item) => acc + (item.quantity * item.unitPrice), 0);
                const tax = subtotal * getConfig().iva;
                const total = subtotal + tax;
                const preview = cart.slice(0, 3).map(item => `
                    <div class="pos-cart-mini-line">
                        <div>
                            <strong>${item.name}</strong>
                            <span>${item.quantity} x ${fmt(item.unitPrice)}</span>
                        </div>
                        <b>${fmt(item.quantity * item.unitPrice)}</b>
                    </div>
                `).join('');

                return `
                    <div class="pos-cart-mini">
                        ${preview}
                        ${cart.length > 3 ? `<div class="text-muted" style="font-weight:700;">+${cart.length - 3} producto${cart.length - 3 === 1 ? '' : 's'} mas</div>` : ''}
                        <div class="pos-cart-mini-total">
                            <span>Total con IVA</span>
                            <strong>${fmt(total)}</strong>
                        </div>
                    </div>
                `;
            }

            function buildCartHtml() {
                if (!cart.length) {
                    return `<div class="text-muted pos-cart-empty" style="padding:.2rem 0 .65rem;">Aún no has agregado productos.</div>`;
                }

                const subtotal = cart.reduce((acc, item) => acc + (item.quantity * item.unitPrice), 0);
                const tax = subtotal * getConfig().iva;
                const total = subtotal + tax;

                return `
                    ${cart.map(item => {
                        const lineTotal = item.quantity * item.unitPrice;
                        return `
                        <div class="pos-cart-item">
                            <div class="pos-cart-item-header">
                                <div>
                                    <strong>${item.name}</strong>
                                    <div class="text-muted" style="font-size:.78rem;">${item.code} · ${fmt(item.unitPrice)} c/u</div>
                                </div>
                                <button class="btn btn-ghost btn-sm" type="button" onclick="removeCartItem(${item.productId})" style="color:var(--danger);width:36px;height:36px;padding:0!important;border-radius:50%!important;flex-shrink:0;">
                                    <i class="fas fa-trash-can"></i>
                                </button>
                            </div>

                            <div class="pos-cart-item-footer">
                                <div class="pos-cart-actions">
                                    <button class="btn btn-outline btn-sm" type="button" onclick="changeQty(${item.productId}, -1)"><i class="fas fa-minus"></i></button>
                                    <span style="font-weight:800;min-width:24px;text-align:center;">${item.quantity}</span>
                                    <button class="btn btn-outline btn-sm" type="button" onclick="changeQty(${item.productId}, 1)"><i class="fas fa-plus"></i></button>
                                </div>
                                <span style="font-weight:800;font-size:1.05rem;color:var(--primary);">${fmt(lineTotal)}</span>
                            </div>
                        </div>
                    `}).join('')}

                    <div class="pos-cart-totals" style="background:color-mix(in srgb, var(--bg-alt) 82%, var(--primary-light) 18%);border-radius:14px;padding:.85rem;margin-top:.5rem;">
                        <div class="pos-total-row" style="padding:.25rem 0;">
                            <span style="color:var(--text-muted);font-size:.85rem;">Subtotal</span>
                            <strong style="font-size:.95rem;">${fmt(subtotal)}</strong>
                        </div>
                        <div class="pos-total-row" style="padding:.25rem 0;">
                            <span style="color:var(--text-muted);font-size:.85rem;">IVA (${(getConfig().iva * 100).toFixed(0)}%)</span>
                            <strong style="font-size:.95rem;">${fmt(tax)}</strong>
                        </div>
                        <div class="hr" style="margin:.35rem 0;"></div>
                        <div class="pos-total-row total-final" style="padding:.25rem 0;">
                            <span style="font-weight:700;">Total</span>
                            <strong style="font-size:1.25rem;color:var(--primary);">${fmt(total)}</strong>
                        </div>
                    </div>
                `;
            }

            window.addToCart = (productId) => {
                if (!getActiveSession()) {
                    app.toast.warning('Debe abrir caja antes de agregar productos al carrito.');
                    const amountInput = document.getElementById('openingAmount');
                    if (amountInput) amountInput.focus();
                    return;
                }

                const product = store.inventory.list().find(x => x.id === productId);
                if (!product) return;

                const existingItem = cart.find(x => x.productId === productId);
                const availableStock = remainingStock(product.id, product.stock);
                if (availableStock <= 0) {
                    app.toast.warning('No hay más stock disponible.');
                    return;
                }

                if (existingItem) {
                    existingItem.quantity++;
                } else {
                    cart.push({
                        productId: product.id,
                        code: product.code,
                        name: product.description,
                        quantity: 1,
                        unitPrice: product.price
                    });
                }

                renderCart();
                openCartPanel();
            };

            window.changeQty = (productId, delta) => {
                const item = cart.find(x => x.productId === productId);
                const product = store.inventory.list().find(x => x.id === productId);

                if (!item || !product) return;

                const newQuantity = item.quantity + delta;

                if (newQuantity <= 0) {
                    removeCartItem(productId);
                    return;
                }

                if (newQuantity > Number(product.stock || 0)) {
                    app.toast.warning('La cantidad supera el stock.');
                    return;
                }

                item.quantity = newQuantity;
                renderCart();
            };

            window.removeCartItem = (productId) => {
                const index = cart.findIndex(x => x.productId === productId);
                if (index >= 0) {
                    cart.splice(index, 1);
                    renderCart();
                }
            };

            window.openSession = async () => {
                try {
                    const amount = document.getElementById('openingAmount')?.value || 0;
                    await store.pos.openSession(amount);
                    app.toast.success('Caja abierta correctamente.');
                    await renderAll();
                } catch (error) {
                    app.toast.error(error.message);
                }
            };

            window.closeSession = async () => {
                try {
                    const session = getActiveSession();
                    if (!session) return;

                    const declared = document.getElementById('declaredCash')?.value || 0;
                    await store.pos.closeSession(session.id, declared);

                    app.toast.info('Caja cerrada correctamente.');
                    await renderAll();
                } catch (error) {
                    app.toast.error(error.message);
                }
            };

            window.togglePaymentMethod = async (id) => {
                if (!permissions.canManagePayments) {
                    app.toast.warning('Solo Admin o Staff puede modificar formas de pago.');
                    return;
                }
                try {
                    await store.pos.togglePaymentMethod(id);
                    app.toast.success('Forma de pago actualizada.');
                    await renderAll();
                } catch (error) {
                    app.toast.error(error.message);
                }
            };

            document.getElementById('paymentMethodForm')?.addEventListener('submit', async (event) => {
                event.preventDefault();
                if (!permissions.canManagePayments) return;

                try {
                    await store.pos.savePaymentMethod(Object.fromEntries(new FormData(event.target).entries()));
                    event.target.reset();
                    app.toast.success('Forma de pago guardada.');
                    await renderAll();
                } catch (error) {
                    app.toast.error(error.message);
                }
            });

            document.getElementById('creditNoteForm')?.addEventListener('submit', async (event) => {
                event.preventDefault();
                if (!permissions.canManageCreditNotes) return;

                try {
                    await store.pos.creditNote(Object.fromEntries(new FormData(event.target).entries()));
                    recentSales = await store.pos.recentSales();
                    event.target.reset();
                    app.toast.success('Nota de credito registrada.');
                    await renderAll();
                } catch (error) {
                    app.toast.error(error.message);
                }
            });

            function handleCheckout(formEl) {
                return async function (event) {
                    event.preventDefault();

                    try {
                        if (!cart.length) {
                            throw new Error('Agrega productos al carrito antes de cobrar.');
                        }

                        const formData = Object.fromEntries(new FormData(formEl).entries());

                        await store.pos.sell({
                            ...formData,
                            items: cart.map(item => ({
                                productId: item.productId,
                                quantity: item.quantity
                            }))
                        });

                        recentSales = await store.pos.recentSales();
                        cart.splice(0, cart.length);
                        formEl.reset();

                        app.toast.success('Venta registrada correctamente.');
                        closeCartPanel();
                        await renderAll();
                    } catch (error) {
                        app.toast.error(error.message);
                    }
                };
            }

            checkoutForm.addEventListener('submit', handleCheckout(checkoutForm));
            const desktopForm = document.getElementById('posCheckoutFormDesktop');
            if (desktopForm) {
                desktopForm.addEventListener('submit', handleCheckout(desktopForm));
            }

            searchInput.addEventListener('input', () => {
                renderProducts();
                renderSummary();
            });

            function openCartPanel() {
                document.body.classList.add('pos-cart-is-open');

                const panel = document.getElementById('posCartPanel');
                if (panel) {
                    panel.style.display = 'block';
                    panel.classList.add('pos-cart-open');
                    panel.setAttribute('aria-hidden', 'false');
                }
            }

            function closeCartPanel() {
                const sheet = document.getElementById('posCartSheet');
                const backdrop = document.getElementById('posCartBackdrop');
                const panel = document.getElementById('posCartPanel');
                document.body.classList.remove('pos-cart-is-open');

                if (sheet) {
                    sheet.classList.remove('open');
                    sheet.setAttribute('aria-hidden', 'true');
                    sheet.style.display = 'none';
                }
                if (backdrop) {
                    backdrop.classList.remove('open');
                    backdrop.style.display = 'none';
                }
                if (panel) {
                    panel.classList.remove('pos-cart-open');
                    panel.setAttribute('aria-hidden', 'true');
                    panel.style.display = 'none';
                }
            }

            const navSignal = app.navigation.getAbortSignal();
            document.getElementById('posCartToggle').addEventListener('click', openCartPanel);
            document.getElementById('posCartClose').addEventListener('click', closeCartPanel);
            document.getElementById('posCartSheetClose').addEventListener('click', closeCartPanel);
            document.getElementById('posCartBackdrop').addEventListener('click', closeCartPanel);
            document.addEventListener('click', (event) => {
                const panel = document.getElementById('posCartPanel');
                const toggle = document.getElementById('posCartToggle');
                if (!panel?.classList.contains('pos-cart-open')) return;
                if (panel.contains(event.target) || toggle.contains(event.target)) return;
                closeCartPanel();
            }, { signal: navSignal });
            document.addEventListener('keydown', (event) => {
                if (event.key === 'Escape') closeCartPanel();
            }, { signal: navSignal });

            document.querySelectorAll('.pos-customer-input').forEach(input => {
                input.addEventListener('change', () => applyCustomerSelection(input));
            });

            async function renderAll() {
                renderSummary();
                renderSessionPanel();
                renderCustomerOptions();
                renderProducts();
                renderCart();
            }

            window.selectCreditNoteSale = (saleId) => {
                const input = document.querySelector('#creditNoteForm [name="saleId"]');
                if (input) {
                    input.value = saleId;
                    input.focus();
                }
            };

            // Cargar sesiones de caja primero, luego refresh general
            store.refreshPos().then(() => store.refresh().then(async () => {
                if (permissions.canManageCreditNotes) {
                    try { recentSales = await store.pos.recentSales(); } catch { recentSales = []; }
                }
                renderAll();
            }).catch(error => app.toast.error(error.message)));
        })();
    </script>
}

