@{
    ViewData["Title"] = "Carrito POS";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-shell pos-cart-page">
    <div class="page-header">
        <div>
            <div class="eyebrow"><i class="fas fa-cash-register"></i> Punto de venta</div>
            <h1>Finalizar venta</h1>
            <p class="text-muted">Revise los productos, seleccione o escriba el cliente y confirme el cobro.</p>
        </div>
        <a class="btn btn-outline" href="/Pos">
            <i class="fas fa-arrow-left"></i>
            Volver al POS
        </a>
    </div>

    <div class="pos-cart-checkout-layout">
        <section class="card pos-cart-checkout-card">
            <div class="pos-panel-header">
                <div>
                    <div class="pos-panel-eyebrow">Detalle</div>
                    <h3 class="pos-panel-title"><i class="fas fa-cart-shopping"></i> Productos</h3>
                </div>
                <span class="badge badge-info" id="checkoutCartCount">0 productos</span>
            </div>
            <div id="checkoutCartItems" class="pos-cart-list"></div>
        </section>

        <aside class="card pos-cart-checkout-card">
            <div class="pos-panel-header">
                <div>
                    <div class="pos-panel-eyebrow">Cliente y cobro</div>
                    <h3 class="pos-panel-title">Datos de venta</h3>
                </div>
            </div>

            <form id="checkoutCartForm" class="pos-checkout-form">
                <div class="pos-form-block">
                    <label>Cliente</label>
                    <input class="form-control" name="customerName" id="checkoutCustomerName" list="checkoutCustomerOptions" placeholder="Buscar cliente o escribir manualmente" />
                    <datalist id="checkoutCustomerOptions"></datalist>
                </div>
                <div class="pos-form-block">
                    <label>Correo</label>
                    <input class="form-control" name="customerEmail" placeholder="correo@cliente.com" />
                </div>
                <div class="pos-form-block">
                    <label>Telefono</label>
                    <input class="form-control" name="customerPhone" placeholder="Telefono" />
                </div>
                <div class="pos-form-block">
                    <label>Metodo de pago</label>
                    <select class="form-control" name="paymentMethod" id="checkoutPaymentMethod"></select>
                </div>
                <div class="pos-form-block">
                    <label>Descuento adicional</label>
                    <input class="form-control" type="number" min="0" step="0.01" name="discountRate" value="0" />
                </div>

                <div id="checkoutTotals" class="pos-cart-totals"></div>

                <button class="btn btn-primary pos-submit-btn" type="submit">
                    <i class="fas fa-check-circle"></i>
                    Confirmar venta
                </button>
            </form>
        </aside>
    </div>
</div>

<div class="pos-payment-modal" id="posPaymentModal" hidden>
    <div class="pos-payment-modal__backdrop" data-pos-payment-close></div>
    <section class="pos-payment-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="posPaymentTitle">
        <button class="pos-payment-modal__close" type="button" data-pos-payment-close aria-label="Cerrar">
            <i class="fas fa-xmark"></i>
        </button>
        <div class="pos-payment-modal__header">
            <span><i class="fas fa-shield-halved"></i></span>
            <div>
                <div class="pos-panel-eyebrow">Pasarela de pago</div>
                <h2 id="posPaymentTitle">Confirmar cobro</h2>
            </div>
        </div>
        <div class="pos-payment-modal__amount">
            <span>Total a cobrar</span>
            <strong id="posPaymentTotal">0</strong>
        </div>
        <form id="posPaymentForm" class="pos-payment-form">
            <label>
                <span>Metodo</span>
                <select class="form-control" name="method" id="posGatewayMethod">
                    <option>Tarjeta</option>
                    <option>SINPE</option>
                    <option>Efectivo</option>
                    <option>Transferencia</option>
                </select>
            </label>
            <label>
                <span id="posGatewayReferenceLabel">Referencia o titular</span>
                <input class="form-control" name="holder" id="posGatewayReference" placeholder="Nombre, SINPE o referencia" required />
            </label>
            <label class="pos-card-field">
                <span>Numero de tarjeta</span>
                <input class="form-control" name="card" inputmode="numeric" maxlength="19" placeholder="4242 4242 4242 4242" />
            </label>
            <div class="pos-payment-form__grid pos-card-field">
                <label><span>Vence</span><input class="form-control" name="expiry" maxlength="5" placeholder="MM/AA" /></label>
                <label><span>CVV</span><input class="form-control" name="cvv" inputmode="numeric" maxlength="4" placeholder="123" /></label>
            </div>
            <p class="pos-payment-modal__note">Simulacion de pasarela: valida datos minimos y registra el cobro en el sistema.</p>
            <button class="btn btn-primary pos-submit-btn" type="submit" id="posPaymentConfirmBtn">
                <i class="fas fa-lock"></i>
                Aprobar cobro
            </button>
        </form>
    </section>
</div>

@section Scripts {
    <script>
        (() => {
            const store = BakeSmartStore;
            const fmt = app.utils.formatCurrency;
            let cart = JSON.parse(sessionStorage.getItem('bakesmart.pos.cart') || '[]');

            const itemsEl = document.getElementById('checkoutCartItems');
            const countEl = document.getElementById('checkoutCartCount');
            const totalsEl = document.getElementById('checkoutTotals');
            const form = document.getElementById('checkoutCartForm');
            const paymentModal = document.getElementById('posPaymentModal');
            const paymentForm = document.getElementById('posPaymentForm');
            const gatewayMethod = document.getElementById('posGatewayMethod');
            const gatewayReferenceLabel = document.getElementById('posGatewayReferenceLabel');
            const gatewayReference = document.getElementById('posGatewayReference');
            const paymentConfirmBtn = document.getElementById('posPaymentConfirmBtn');
            let pendingOrder = null;
            let pendingTotals = null;

            function saveCart() {
                sessionStorage.setItem('bakesmart.pos.cart', JSON.stringify(cart));
            }

            function renderCustomers() {
                document.getElementById('checkoutCustomerOptions').innerHTML = store.customers.list().map(customer => `
                            <option value="${customer.fullName || customer.name || ''}">
                                ${customer.email || customer.phone || 'Cliente registrado'}
                            </option>
                        `).join('');
            }

            function renderPayments() {
                document.getElementById('checkoutPaymentMethod').innerHTML = store.pos.config().paymentMethods
                    .filter(method => method.active)
                    .map(method => `<option value="${method.name}">${method.name}</option>`)
                    .join('');
            }

            function readPendingOrder() {
                try {
                    const raw = sessionStorage.getItem('bakesmart.pos.pendingOrder');
                    pendingOrder = raw ? JSON.parse(raw) : null;
                } catch {
                    pendingOrder = null;
                }

                if (!pendingOrder) return;
                form.customerName.value = pendingOrder.customerName || '';
                form.customerEmail.value = pendingOrder.customerEmail || '';
                if (pendingOrder.paymentMethod) {
                    form.paymentMethod.value = pendingOrder.paymentMethod;
                    form.paymentMethod.dispatchEvent(new Event('change', { bubbles: true }));
                }
            }

            function selectedCustomer() {
                const email = String(form.customerEmail.value || '').trim().toLowerCase();
                const name = String(form.customerName.value || '').trim().toLowerCase();
                return store.customers.list().find(row =>
                    (email && String(row.email || '').trim().toLowerCase() === email) ||
                    (name && String(row.fullName || row.name || '').trim().toLowerCase() === name)
                );
            }

            function currentDiscountBreakdown() {
                const manual = Math.min(Math.max(Number(form.discountRate?.value || 0), 0), 1);
                const customer = selectedCustomer();
                const frequent = customer?.frequent ? Math.min(Math.max(Number(store.pos.config().frequentCustomerDiscount || 0), 0), 1) : 0;
                const totalRate = Math.min(manual + frequent, 1);
                return { manual, frequent, totalRate, customer };
            }

            function remainingStock(productId) {
                const product = store.inventory.list().find(row => Number(row.id) === Number(productId));
                const item = cart.find(row => Number(row.productId) === Number(productId));
                return Math.max(0, Number(product?.stock || 0) - Number(item?.quantity || 0));
            }

            function renderCart() {
                countEl.textContent = `${cart.length} producto${cart.length === 1 ? '' : 's'}`;

                if (!cart.length) {
                    itemsEl.innerHTML = `<div class="pos-cart-mini-empty"><i class="fas fa-basket-shopping"></i><strong>Carrito vacio</strong><span>Vuelva al POS para agregar productos.</span></div>`;
                    totalsEl.innerHTML = '';
                    return;
                }

                itemsEl.innerHTML = cart.map(item => `
                            <div class="pos-cart-item">
                                <div class="pos-cart-item-header">
                                    <div>
                                        <strong>${item.name}</strong>
                                        <div class="text-muted" style="font-size:.82rem;">${item.code} - ${fmt(item.unitPrice)} c/u · ${remainingStock(item.productId)} disponibles</div>
                                    </div>
                                    <button class="btn btn-ghost btn-sm" type="button" onclick="removeCheckoutItem(${item.productId})">
                                        <i class="fas fa-trash-can"></i>
                                    </button>
                                </div>
                                <div class="pos-cart-item-footer">
                                    <div class="pos-cart-actions">
                                        <button class="btn btn-outline btn-sm" type="button" onclick="changeCheckoutQty(${item.productId}, -1)"><i class="fas fa-minus"></i></button>
                                        <span style="font-weight:800;min-width:24px;text-align:center;">${item.quantity}</span>
                                        <button class="btn btn-outline btn-sm" type="button" onclick="changeCheckoutQty(${item.productId}, 1)" ${remainingStock(item.productId) <= 0 ? 'disabled' : ''}><i class="fas fa-plus"></i></button>
                                    </div>
                                    <strong style="color:var(--primary);">${fmt(item.quantity * item.unitPrice)}</strong>
                                </div>
                            </div>
                        `).join('');

                const subtotal = cart.reduce((sum, item) => sum + item.quantity * item.unitPrice, 0);
                const discountBreakdown = currentDiscountBreakdown();
                const discountRate = discountBreakdown.totalRate;
                const discount = subtotal * discountRate;
                const discountedSubtotal = Math.max(0, subtotal - discount);
                const tax = discountedSubtotal * Number(store.pos.config().iva || 0);
                const total = pendingOrder?.total ? Number(pendingOrder.total) : discountedSubtotal + tax;
                pendingTotals = { subtotal, discount, tax, total };
                totalsEl.innerHTML = `
                            ${pendingOrder ? `<div class="pos-total-row"><span>Pedido existente</span><strong>#${pendingOrder.id}</strong></div>` : ''}
                            <div class="pos-total-row"><span>Subtotal</span><strong>${fmt(subtotal)}</strong></div>
                            ${discountBreakdown.frequent > 0 ? `<div class="pos-total-row"><span>Cliente frecuente ${Math.round(discountBreakdown.frequent * 100)}%</span><strong>Aplica</strong></div>` : `<div class="pos-total-row"><span>Cliente frecuente</span><strong>0%</strong></div>`}
                            ${discountBreakdown.manual > 0 ? `<div class="pos-total-row"><span>Descuento adicional ${Math.round(discountBreakdown.manual * 100)}%</span><strong>Aplica</strong></div>` : ''}
                            ${discount > 0 ? `<div class="pos-total-row"><span>Descuento total ${Math.round(discountRate * 100)}%</span><strong>-${fmt(discount)}</strong></div>` : ''}
                            <div class="pos-total-row"><span>IVA</span><strong>${fmt(tax)}</strong></div>
                            <div class="hr"></div>
                            <div class="pos-total-row total-final"><span>Total</span><strong>${fmt(total)}</strong></div>
                        `;
            }

            function shouldShowCardFields(method) {
                const value = String(method || '').toLowerCase();
                return value.includes('tarjeta');
            }

            function syncGatewayFields() {
                const show = shouldShowCardFields(gatewayMethod.value);
                document.querySelectorAll('.pos-card-field').forEach(field => {
                    field.hidden = !show;
                    field.style.display = show ? '' : 'none';
                    field.querySelectorAll('input').forEach(input => {
                        input.disabled = !show;
                        input.required = show;
                        if (!show) input.value = '';
                    });
                });

                const method = String(gatewayMethod.value || '').toLowerCase();
                if (method.includes('efectivo')) {
                    gatewayReferenceLabel.textContent = 'Recibido por';
                    gatewayReference.placeholder = 'Nombre de quien recibe el efectivo';
                    gatewayReference.required = false;
                } else if (method.includes('sinpe')) {
                    gatewayReferenceLabel.textContent = 'Referencia SINPE';
                    gatewayReference.placeholder = 'Telefono o comprobante SINPE';
                    gatewayReference.required = true;
                } else if (method.includes('transfer')) {
                    gatewayReferenceLabel.textContent = 'Referencia de transferencia';
                    gatewayReference.placeholder = 'Numero de comprobante o banco';
                    gatewayReference.required = true;
                } else {
                    gatewayReferenceLabel.textContent = 'Titular de la tarjeta';
                    gatewayReference.placeholder = 'Nombre del titular';
                    gatewayReference.required = true;
                }
            }

            function openPaymentModal() {
                if (paymentModal.parentElement !== document.body) {
                    document.body.appendChild(paymentModal);
                }
                const method = form.paymentMethod.value || 'Tarjeta';
                gatewayMethod.value = String(method).toLowerCase().includes('sinpe') ? 'SINPE'
                    : String(method).toLowerCase().includes('efectivo') ? 'Efectivo'
                        : String(method).toLowerCase().includes('transfer') ? 'Transferencia'
                            : 'Tarjeta';
                document.getElementById('posPaymentTotal').textContent = fmt(pendingTotals?.total || 0);
                paymentForm.holder.value = form.customerName.value || '';
                gatewayMethod.dispatchEvent(new Event('change', { bubbles: true }));
                syncGatewayFields();
                paymentModal.hidden = false;
            }

            function closePaymentModal() {
                paymentModal.hidden = true;
                paymentForm.reset();
                syncGatewayFields();
            }

            window.changeCheckoutQty = (productId, delta) => {
                const item = cart.find(row => Number(row.productId) === Number(productId));
                if (!item) return;
                if (delta > 0 && remainingStock(productId) <= 0) {
                    app.toast.warning('La cantidad supera el stock disponible.');
                    return;
                }
                item.quantity += delta;
                if (item.quantity <= 0) cart = cart.filter(row => Number(row.productId) !== Number(productId));
                saveCart();
                renderCart();
            };

            window.removeCheckoutItem = (productId) => {
                cart = cart.filter(row => Number(row.productId) !== Number(productId));
                saveCart();
                renderCart();
            };

            document.getElementById('checkoutCustomerName').addEventListener('change', event => {
                const selected = store.customers.list().find(customer =>
                    String(customer.fullName || customer.name || '').toLowerCase() === String(event.target.value || '').toLowerCase()
                );
                if (!selected) return;
                form.customerEmail.value = selected.email || '';
                form.customerPhone.value = selected.phone || '';
                renderCart();
            });

            form.discountRate.addEventListener('input', renderCart);
            form.customerEmail.addEventListener('input', renderCart);
            form.customerName.addEventListener('input', renderCart);

            async function completeCheckout(paymentData) {
                try {
                    await store.pos.sessions();
                    if (!pendingOrder && !store.pos.activeSession()) throw new Error('Debe abrir caja antes de confirmar ventas.');
                    if (!cart.length) throw new Error('Agregue productos al carrito antes de cobrar.');

                    if (pendingOrder) {
                        await store.orders.markPaid(pendingOrder.id, paymentData.method || form.paymentMethod.value || 'Tarjeta');
                        sessionStorage.removeItem('bakesmart.pos.pendingOrder');
                    } else {
                        await store.pos.sell({
                            ...Object.fromEntries(new FormData(form).entries()),
                            paymentMethod: paymentData.method || form.paymentMethod.value,
                            items: cart.map(item => ({ productId: item.productId, quantity: item.quantity }))
                        });
                    }

                    cart = [];
                    saveCart();
                    app.toast.success(pendingOrder ? 'Pago del pedido confirmado.' : 'Venta registrada correctamente.');
                    app.navigation.navigate(pendingOrder ? '/Production' : '/Pos');
                } catch (error) {
                    app.toast.error(error.message);
                    throw error;
                }
            }

            form.addEventListener('submit', async event => {
                event.preventDefault();
                try {
                    if (!cart.length) throw new Error('Agregue productos al carrito antes de cobrar.');
                    openPaymentModal();
                } catch (error) {
                    app.toast.error(error.message);
                }
            });

            gatewayMethod.addEventListener('change', syncGatewayFields);
            document.querySelectorAll('[data-pos-payment-close]').forEach(button => button.addEventListener('click', closePaymentModal));

            paymentForm.addEventListener('submit', async event => {
                event.preventDefault();
                const data = Object.fromEntries(new FormData(paymentForm).entries());
                if (shouldShowCardFields(data.method)) {
                    const digits = String(data.card || '').replace(/\D/g, '');
                    if (digits.length < 12 || !data.expiry || !data.cvv) {
                        app.toast.error('Complete los datos de tarjeta para aprobar el cobro.');
                        return;
                    }
                }

                try {
                    paymentConfirmBtn.disabled = true;
                    await completeCheckout(data);
                    closePaymentModal();
                } catch {
                    // completeCheckout already reports the error.
                } finally {
                    paymentConfirmBtn.disabled = false;
                }
            });

            async function initializeCheckout() {
                try {
                    await store.pos.sessions();
                    await store.refresh();
                    renderCustomers();
                    renderPayments();
                    readPendingOrder();
                    renderCart();
                } catch (error) {
                    app.toast.error(error.message);
                }
            }

            initializeCheckout();
        })();
    </script>
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/pos-index.css" asp-append-version="true" />
}
