
@section Styles {
    <link rel="stylesheet" href="~/css/pages/client-track.css" asp-append-version="true" />
}
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Seguimiento";
}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>

<div class="page-shell track-page track-page--loading" id="trackPage">
    <div class="page-header track-header">
        <div>
            <h1 class="track-title">
                <i class="fas fa-route"></i>
                Seguimiento inteligente del pedido
            </h1>
            <p class="text-muted track-subtitle">
                El mapa utiliza el origen configurado y la ubicacion real registrada para cada pedido.
            </p>
        </div>

        <div class="track-toolbar">
            <select id="trackOrderSelect" class="form-control track-select"></select>
            <select id="trackPresetSelect" class="form-control track-select-secondary"></select>
        </div>
    </div>

    <div class="grid grid-4 track-kpis">
        <div class="card metric-card">
            <div class="text-muted">Pedido</div>
            <h2 id="trackOrderId"></h2>
        </div>
        <div class="card metric-card">
            <div class="text-muted">Estado</div>
            <h2 id="trackStatus"></h2>
        </div>
        <div class="card metric-card">
            <div class="text-muted">Tipo de ruta</div>
            <h2 id="trackRouteType"></h2>
        </div>
        <div class="card metric-card">
            <div class="text-muted">Destino</div>
            <h2 id="trackDestinationCountry"></h2>
        </div>
    </div>

    <div class="track-layout">
        <div class="card track-map-card">
            <div class="track-map-header">
                <div>
                    <h3 class="track-section-title">Trayectoria visual</h3>
                    <div id="trackMeta" class="text-muted track-map-meta">Calculando ruta...</div>
                </div>

                <div class="map-legend">
                    <span><i class="fas fa-store"></i> Origen</span>
                    <span><i class="fas fa-motorcycle"></i> Entrega local</span>
                    <span><i class="fas fa-plane"></i> Ruta internacional</span>
                    <span><i class="fas fa-location-dot"></i> Destino</span>
                </div>
            </div>

            <div id="deliveryMap" class="delivery-map"></div>
        </div>

        <div class="track-side-stack">
            <div class="card">
                <div class="track-side-header">
                    <h3 class="track-section-title">Progreso del pedido</h3>
                    <span class="badge badge-info"><i class="fas fa-eye"></i> Solo lectura</span>
                </div>
                <div id="trackingTimeline" class="tracking-timeline"></div>
            </div>

            <div class="card">
                <h3 class="track-section-title track-summary-title">Resumen logÃ­stico</h3>
                <div id="trackingSummary" class="tracking-summary text-muted"></div>
            </div>
        </div>
    </div>
</div>



@section Scripts {
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script>
(() => {
    const page = document.getElementById('trackPage');
    const origin = BakeSmartStore.geo.origin();
    const presetSelect = document.getElementById('trackPresetSelect');
    const orderSelect = document.getElementById('trackOrderSelect');
    const userEmail = document.body.dataset.userEmail || '';

    const presetOptions = [
        { id: 'auto', name: 'Destino real del pedido', country: '-' },
        ...BakeSmartStore.geo.presets().map(p => ({ id: p.id, name: p.name, country: p.country }))
    ];

    let map;
    let markers = [];
    let layers = [];
    let animationTimer = null;
    let activeOrderId = null;
    let activeAnimatedMarker = null;
    let pageInitialized = false;

    function showPage() {
        page.classList.remove('track-page--loading');
        page.classList.add('track-page--ready');
    }

    function createPinHtml(iconClass, extraClass = '', staticPulse = false) {
        return `
            <div class="track-pin-wrap ${extraClass} ${staticPulse ? 'track-pin-static' : 'track-pin-moving'}">
                <div class="track-pin-pulse"></div>
                <div class="track-pin-core">
                    <i class="fas ${iconClass}"></i>
                </div>
            </div>
        `;
    }

    function makeIcon(iconClass, extraClass = '', staticPulse = false) {
        if (!window.L) return null;

        return L.divIcon({
            className: 'track-marker-icon',
            html: createPinHtml(iconClass, extraClass, staticPulse),
            iconSize: [42, 42],
            iconAnchor: [21, 21],
            popupAnchor: [0, -18]
        });
    }

    function getIcons() {
        return {
            origin: makeIcon('fa-store', 'track-pin-origin', true),
            destination: makeIcon('fa-location-dot', 'track-pin-destination', true),
            courier: makeIcon('fa-motorcycle', 'track-pin-courier'),
            plane: makeIcon('fa-plane', 'track-pin-plane')
        };
    }

    function getOrders() {
        const own = BakeSmartStore.orders.byClient(userEmail);
        return own.length ? own : BakeSmartStore.orders.list();
    }

    function ensureMap() {
        if (!window.L) return null;
        if (map) return map;

        map = L.map('deliveryMap', {
            zoomControl: true,
            worldCopyJump: true,
            preferCanvas: true
        }).setView([origin.lat, origin.lng], 10);

        L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
            subdomains: 'abcd',
            maxZoom: 19,
            attribution: '&copy; OpenStreetMap &copy; CARTO'
        }).addTo(map);

        return map;
    }

    function clearVisuals() {
        markers.forEach(m => m.remove());
        layers.forEach(l => l.remove());
        markers = [];
        layers = [];

        if (animationTimer) {
            clearInterval(animationTimer);
            animationTimer = null;
        }

        if (activeAnimatedMarker) {
            activeAnimatedMarker.remove();
            activeAnimatedMarker = null;
        }
    }

    function interpolate(start, end, t) {
        return [
            start[0] + ((end[0] - start[0]) * t),
            start[1] + ((end[1] - start[1]) * t)
        ];
    }

    function curveBetween(start, end, isInternational, bendDirection = 1) {
        const steps = isInternational ? 64 : 26;
        const dx = end[1] - start[1];
        const dy = end[0] - start[0];
        const distance = Math.sqrt((dx * dx) + (dy * dy)) || 0.001;

        const mid = [
            (start[0] + end[0]) / 2,
            (start[1] + end[1]) / 2
        ];

        const perpendicular = [-(dx / distance), dy / distance];
        const bend = isInternational
            ? Math.min(Math.max(distance * 0.16, 0.18), 0.55)
            : Math.min(Math.max(distance * 0.06, 0.01), 0.035);

        const control = [
            mid[0] + (perpendicular[0] * bend * bendDirection),
            mid[1] + (perpendicular[1] * bend * bendDirection)
        ];

        const points = [];
        for (let i = 0; i <= steps; i++) {
            const t = i / steps;
            const lat = ((1 - t) * (1 - t) * start[0]) + (2 * (1 - t) * t * control[0]) + (t * t * end[0]);
            const lng = ((1 - t) * (1 - t) * start[1]) + (2 * (1 - t) * t * control[1]) + (t * t * end[1]);
            points.push([lat, lng]);
        }

        return points;
    }

    function buildLocalRoute(start, end, progressStep) {
        const operationPoint = interpolate(start, end, 0.45);
        operationPoint[0] += 0.012;
        operationPoint[1] -= 0.01;

        const firstLeg = curveBetween(start, operationPoint, false, -1);
        const secondLeg = curveBetween(operationPoint, end, false, 1);
        const combined = [...firstLeg, ...secondLeg.slice(1)];

        const normalized = Math.min(Math.max((progressStep || 0) / 4, 0.12), 0.94);
        const courierIndex = Math.min(combined.length - 1, Math.max(0, Math.round(normalized * (combined.length - 1))));

        return {
            operationPoint,
            firstLeg,
            secondLeg,
            combined,
            courierLatLng: combined[courierIndex]
        };
    }

    function animateMarker(points, icon) {
        if (!points.length) return;

        activeAnimatedMarker = L.marker(points[0], { icon }).addTo(map);

        let index = 0;
        animationTimer = setInterval(() => {
            index = (index + 1) % points.length;
            activeAnimatedMarker.setLatLng(points[index]);
        }, 120);
    }

    function activePreset(order) {
        const presetId = presetSelect.value;

        if (!presetId || presetId === 'auto') {
            return BakeSmartStore.geo.resolveDestination(order.address, {
                lat: order.tracking.destinationLat,
                lng: order.tracking.destinationLng
            });
        }

        const preset = BakeSmartStore.geo.presets().find(p => p.id === presetId);
        return BakeSmartStore.geo.resolveDestination(preset?.name || order.address, preset || {});
    }

    function renderTimeline(order, destination) {
        const currentStep = order.tracking.currentStep || 0;
        const isInternational = destination.country !== 'Costa Rica';
        const extraLabel = isInternational ? 'Salida aÃ©rea internacional' : 'Ruta terrestre metropolitana';
        const steps = [...order.tracking.steps];

        if (!steps.includes(extraLabel)) {
            steps.splice(4, 0, extraLabel);
        }

        document.getElementById('trackingTimeline').innerHTML = steps.map((step, index) => {
            const normalizedCurrent = isInternational && currentStep >= 3 ? currentStep + 1 : currentStep;
            const state = index < normalizedCurrent ? 'done' : index === normalizedCurrent ? 'current' : 'pending';
            const icon = state === 'done' ? 'fa-check' : state === 'current' ? 'fa-bolt' : 'fa-clock';

            return `
                <div class="timeline-item timeline-${state}">
                    <div class="timeline-dot"><i class="fas ${icon}"></i></div>
                    <div class="timeline-content">
                        <div class="timeline-title">${step}</div>
                        <div class="text-muted">${state === 'done' ? 'Completado' : state === 'current' ? 'Estado actual' : 'Pendiente'}</div>
                    </div>
                </div>
            `;
        }).join('');
    }

    function renderTrackingSummary(order, destination, routeType) {
        document.getElementById('trackingSummary').innerHTML = `
            <div class="summary-row"><span>Origen</span><strong>${origin.name}</strong></div>
            <div class="summary-row"><span>Cliente</span><strong>${order.customerName}</strong></div>
            <div class="summary-row"><span>Direccion</span><strong>${order.address}</strong></div>
            <div class="summary-row"><span>Destino visual</span><strong>${destination.name}</strong></div>
            <div class="summary-row"><span>Latitud / longitud</span><strong>${destination.lat.toFixed(5)}, ${destination.lng.toFixed(5)}</strong></div>
            <div class="summary-row"><span>Modalidad</span><strong>${routeType}</strong></div>
            <div class="summary-row"><span>Entrega</span><strong>${new Date(order.deliveryDate).toLocaleDateString('es-CR')}</strong></div>
            <div class="summary-row"><span>Productos</span><strong>${order.items.map(i => `${i.quantity} x ${i.name}`).join(', ')}</strong></div>
            <div class="summary-row"><span>Pago</span><strong>${order.paymentStatus} (${order.paymentMethod || 'Pendiente'})</strong></div>
        `;
    }

    function renderMapFallback(order, destination, routeType) {
        document.getElementById('deliveryMap').innerHTML = `
            <div class="track-fallback-map">
                <div class="track-fallback-node">
                    <span><i class="fas fa-store"></i></span>
                    <strong>${origin.name}</strong>
                    <small>${origin.city}, ${origin.country}</small>
                </div>
                <div class="track-fallback-route">
                    <i class="fas ${routeType.includes('aerea') ? 'fa-plane' : 'fa-motorcycle'}"></i>
                    <span>${order.status}</span>
                </div>
                <div class="track-fallback-node">
                    <span><i class="fas fa-location-dot"></i></span>
                    <strong>${destination.name}</strong>
                    <small>${destination.country}</small>
                </div>
            </div>
        `;
    }

    function renderOrder(orderId) {
        const orders = getOrders();
        const order = orders.find(x => Number(x.id) === Number(orderId)) || orders[0];
        if (!order) return;

        activeOrderId = order.id;

        const destination = activePreset(order);
        const isInternational = destination.country !== 'Costa Rica';
        const routeType = isInternational ? 'Trayectoria aÃ©rea' : 'Trayecto local';
        document.getElementById('trackOrderId').textContent = `#${order.id}`;
        document.getElementById('trackStatus').textContent = order.status;
        document.getElementById('trackRouteType').textContent = routeType;
        document.getElementById('trackDestinationCountry').textContent = destination.country;
        document.getElementById('trackMeta').textContent = `${origin.city}, ${origin.country} -> ${destination.name}, ${destination.country}`;

        clearVisuals();
        renderTimeline(order, destination);
        renderTrackingSummary(order, destination, routeType);

        const mapInstance = ensureMap();
        if (!mapInstance) {
            renderMapFallback(order, destination, routeType);
            return;
        }

        const icons = getIcons();

        const startLatLng = [origin.lat, origin.lng];
        const destinationLatLng = [destination.lat, destination.lng];
        const flightPath = curveBetween(startLatLng, destinationLatLng, true, -1);
        const localRoute = buildLocalRoute(startLatLng, destinationLatLng, order.tracking.currentStep || 0);

        const originMarker = L.marker(startLatLng, { icon: icons.origin }).addTo(mapInstance).bindPopup(`${origin.name}<br>${origin.lat.toFixed(4)}, ${origin.lng.toFixed(4)}`);
        const destinationMarker = L.marker(destinationLatLng, { icon: icons.destination }).addTo(mapInstance).bindPopup(`${destination.name}<br>${destination.lat.toFixed(4)}, ${destination.lng.toFixed(4)}`);

        markers.push(originMarker, destinationMarker);

        if (isInternational) {
            const routeShadow = L.polyline(flightPath, {
                color: '#7c3aed',
                weight: 10,
                opacity: .16,
                smoothFactor: 1.4
            }).addTo(mapInstance);

            const route = L.polyline(flightPath, {
                color: '#6d28d9',
                weight: 4,
                dashArray: '10 14',
                opacity: .95,
                smoothFactor: 1.4
            }).addTo(mapInstance);

            layers.push(routeShadow, route);
            animateMarker(flightPath, icons.plane);
        } else {
            const operationMarker = L.marker(localRoute.operationPoint, {
                icon: icons.courier
            }).addTo(mapInstance).bindPopup('OperaciÃ³n local');

            const firstLeg = L.polyline(localRoute.firstLeg, {
                color: '#f59e0b',
                weight: 4,
                opacity: .82,
                dashArray: '6 10',
                smoothFactor: 1.2
            }).addTo(mapInstance);

            const secondLeg = L.polyline(localRoute.secondLeg, {
                color: '#10b981',
                weight: 4,
                opacity: .95,
                smoothFactor: 1.2
            }).addTo(mapInstance);

            markers.push(operationMarker);
            layers.push(firstLeg, secondLeg);
            animateMarker(localRoute.secondLeg, icons.courier);
        }

        const fitPoints = isInternational
            ? [startLatLng, destinationLatLng, ...flightPath]
            : localRoute.combined;

        mapInstance.fitBounds(L.latLngBounds(fitPoints), { padding: [48, 48] });

        requestAnimationFrame(() => {
            mapInstance.invalidateSize(true);
        });

        renderTimeline(order, destination);

        document.getElementById('trackingSummary').innerHTML = `
            <div class="summary-row"><span>Origen</span><strong>${origin.name}</strong></div>
            <div class="summary-row"><span>Cliente</span><strong>${order.customerName}</strong></div>
            <div class="summary-row"><span>DirecciÃ³n</span><strong>${order.address}</strong></div>
            <div class="summary-row"><span>Destino visual</span><strong>${destination.name}</strong></div>
            <div class="summary-row"><span>Latitud / longitud</span><strong>${destination.lat.toFixed(5)}, ${destination.lng.toFixed(5)}</strong></div>
            <div class="summary-row"><span>Modalidad</span><strong>${routeType}</strong></div>
            <div class="summary-row"><span>Entrega</span><strong>${new Date(order.deliveryDate).toLocaleDateString('es-CR')}</strong></div>
            <div class="summary-row"><span>Productos</span><strong>${order.items.map(i => `${i.quantity} x ${i.name}`).join(', ')}</strong></div>
            <div class="summary-row"><span>Pago</span><strong>${order.paymentStatus} (${order.paymentMethod || 'Pendiente'})</strong></div>
        `;
    }

    function renderSelector() {
        const orders = getOrders();

        orderSelect.innerHTML = orders.map(o =>
            `<option value="${o.id}">#${o.id} Â· ${o.customerName} Â· ${o.status}</option>`
        ).join('');

        presetSelect.innerHTML = presetOptions.map(p =>
            `<option value="${p.id}">${p.name}${p.country && p.country !== '-' ? ` Â· ${p.country}` : ''}</option>`
        ).join('');

        renderOrder(orders[0]?.id);
    }

    orderSelect.addEventListener('change', () => renderOrder(orderSelect.value));
    presetSelect.addEventListener('change', () => renderOrder(orderSelect.value));

    async function initializePage() {
        if (pageInitialized) return;
        pageInitialized = true;

        try {
            await BakeSmartStore.refresh();
            renderSelector();
        } finally {
            requestAnimationFrame(() => {
                showPage();
                if (map) {
                    map.invalidateSize(true);
                }
            });
        }
    }

    app.page.ready(initializePage);
})();
</script>
}

