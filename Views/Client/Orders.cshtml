
@section Styles {
    <link rel="stylesheet" href="~/css/pages/client-orders.css" asp-append-version="true" />
}
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Mis pedidos";
}

<div class="page-shell client-orders-page">
    <div class="page-header client-orders-header">
        <div>
            <h1 class="client-orders-title">
                <i class="fas fa-box-open"></i>
                Mis pedidos
            </h1>
            <p class="text-muted client-orders-subtitle">Consulta entregas, pagos y productos sin depender de una tabla apretada.</p>
        </div>

        <div class="client-orders-actions">
            <input id="clientOrderSearch" class="form-control" placeholder="Buscar pedido o producto" />
            <select id="clientStatusFilter" class="form-control">
                <option value="">Todos los estados</option>
                <option>Pendiente pago</option>
                <option>Confirmado</option>
                <option>En produccion</option>
                <option>Listo</option>
                <option>En camino</option>
                <option>Entregado</option>
            </select>
            <a href="/Client/Track" class="btn btn-primary">
                <i class="fas fa-map-location-dot"></i>
                Seguimiento
            </a>
        </div>
    </div>

    <div class="grid grid-4 client-orders-kpis">
        <div class="card metric-card">
            <div class="text-muted">Pedidos</div>
            <h2 id="clientOrdersCount">0</h2>
        </div>
        <div class="card metric-card">
            <div class="text-muted">Activos</div>
            <h2 id="clientOrdersActive">0</h2>
        </div>
        <div class="card metric-card">
            <div class="text-muted">Pendiente de pago</div>
            <h2 id="clientOrdersPending">0</h2>
        </div>
        <div class="card metric-card">
            <div class="text-muted">Total</div>
            <h2 id="clientOrdersTotal">₡0</h2>
        </div>
    </div>

    <section class="card client-notifications-card">
        <div class="client-notifications-head">
            <div>
                <span class="client-notifications-eyebrow">Notificaciones</span>
                <h2>Actualizaciones de tus pedidos</h2>
            </div>
            <span class="badge badge-info" id="clientNotificationsCount">0 avisos</span>
        </div>
        <div id="clientNotificationsList" class="client-notifications-list"></div>
    </section>

    <div class="client-orders-list" id="clientOrdersList"></div>
</div>

<div class="payment-modal" id="ordersPaymentModal" hidden>
    <div class="payment-modal__backdrop" data-payment-close></div>
    <section class="payment-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="ordersPaymentTitle">
        <button class="payment-modal__close" type="button" data-payment-close aria-label="Cerrar">
            <i class="fas fa-xmark"></i>
        </button>
        <div class="payment-modal__header">
            <span class="payment-modal__icon"><i class="fas fa-shield-halved"></i></span>
            <div>
                <span class="payment-modal__eyebrow">Pasarela de pago</span>
                <h2 id="ordersPaymentTitle">Pagar pedido</h2>
            </div>
        </div>
        <div class="payment-modal__amount">
            <span>Total</span>
            <strong id="ordersPaymentTotal">0</strong>
        </div>
        <form id="ordersPaymentForm" class="payment-form">
            <label>
                <span>Metodo</span>
                <select class="form-control" name="method" id="ordersPaymentMethod">
                    <option>Tarjeta</option>
                    <option>SINPE</option>
                </select>
            </label>
            <label>
                <span>Titular</span>
                <input class="form-control" name="holder" required placeholder="Nombre del titular" />
            </label>
            <label class="payment-card-field">
                <span>Tarjeta</span>
                <input class="form-control" name="card" maxlength="19" inputmode="numeric" placeholder="4242 4242 4242 4242" />
            </label>
            <div class="payment-form__grid payment-card-field">
                <label>
                    <span>Vence</span>
                    <input class="form-control" name="expiry" maxlength="5" placeholder="MM/AA" />
                </label>
                <label>
                    <span>CVV</span>
                    <input class="form-control" name="cvv" maxlength="4" inputmode="numeric" placeholder="123" />
                </label>
            </div>
            <p class="payment-modal__note">Simulacion segura: no se guarda informacion sensible.</p>
            <button class="btn btn-primary" type="submit" id="ordersPaymentSubmit">
                <i class="fas fa-lock"></i>
                Confirmar pago
            </button>
        </form>
    </section>
</div>

@section Scripts {
    <script>
        (() => {
            const userEmail = document.body.dataset.userEmail || '';
            const search = document.getElementById('clientOrderSearch');
            const statusFilter = document.getElementById('clientStatusFilter');
            const list = document.getElementById('clientOrdersList');
            const paymentModal = document.getElementById('ordersPaymentModal');
            const paymentForm = document.getElementById('ordersPaymentForm');
            const paymentMethod = document.getElementById('ordersPaymentMethod');
            const paymentSubmit = document.getElementById('ordersPaymentSubmit');
            let selectedOrder = null;

            function badgeForPayment(status) {
                return status === 'Pagado' ? 'badge-success' : 'badge-warning';
            }

            function itemsLabel(order) {
                return order.items.map(i => `${i.quantity} x ${i.name}`).join(', ');
            }

            function filteredOrders() {
                const q = search.value.trim().toLowerCase();
                const status = statusFilter.value;

                return BakeSmartStore.orders.byClient(userEmail).filter(order => {
                    const matchesQuery = !q
                        || String(order.id).includes(q)
                        || order.customerName.toLowerCase().includes(q)
                        || itemsLabel(order).toLowerCase().includes(q);
                    const matchesStatus = !status || order.status === status;
                    return matchesQuery && matchesStatus;
                });
            }

            function renderNotifications(allOrders) {
                const notifications = allOrders.slice(0, 8).map(order => {
                    const paid = order.paymentStatus === 'Pagado';
                    return {
                        icon: paid ? 'fa-bell' : 'fa-credit-card',
                        title: paid ? `Pedido #${order.id}: ${order.status}` : `Pedido #${order.id}: pago pendiente`,
                        message: paid
                            ? `Tu pedido esta en estado "${order.status}". Revisa seguimiento para ver su avance.`
                            : 'Confirma el pago para que el pedido avance al flujo operativo.'
                    };
                });

                document.getElementById('clientNotificationsCount').textContent =
                    `${notifications.length} aviso${notifications.length === 1 ? '' : 's'}`;
                document.getElementById('clientNotificationsList').innerHTML = notifications.map(item => `
                    <article class="client-notification">
                        <span class="client-notification__icon"><i class="fas ${item.icon}"></i></span>
                        <span>
                            <strong>${item.title}</strong>
                            <small>${item.message}</small>
                        </span>
                        <a class="btn btn-outline btn-sm" href="/Client/Track">Ver</a>
                    </article>
                `).join('') || `
                    <div class="client-empty-state client-empty-state--compact">
                        <h3>Sin notificaciones</h3>
                        <p class="text-muted">Cuando un pedido cambie de estado, aparecera aqui.</p>
                    </div>
                `;
            }

            function render() {
                const allOrders = BakeSmartStore.orders.byClient(userEmail);
                const rows = filteredOrders();
                const pendingTotal = allOrders
                    .filter(order => order.paymentStatus !== 'Pagado')
                    .reduce((acc, order) => acc + order.total, 0);

                document.getElementById('clientOrdersCount').textContent = allOrders.length;
                document.getElementById('clientOrdersActive').textContent = allOrders.filter(order => order.status !== 'Entregado').length;
                document.getElementById('clientOrdersPending').textContent = app.utils.formatCurrency(pendingTotal);
                document.getElementById('clientOrdersTotal').textContent = app.utils.formatCurrency(allOrders.reduce((acc, order) => acc + order.total, 0));
                renderNotifications(allOrders);

                list.innerHTML = rows.map(order => `
                    <article class="card client-order-card">
                        <div class="client-order-top">
                            <div>
                                <h3 class="client-order-id"><i class="fas fa-receipt"></i> Pedido #${order.id}</h3>
                                <div class="text-muted">${new Date(order.createdAt).toLocaleString('es-CR')}</div>
                            </div>
                            <div class="client-order-statuses">
                                <span class="badge badge-primary">${order.status}</span>
                                <span class="badge ${badgeForPayment(order.paymentStatus)}">${order.paymentStatus}</span>
                            </div>
                        </div>

                        <div class="client-order-grid">
                            <div class="client-order-field">
                                <span>Productos</span>
                                <strong>${itemsLabel(order)}</strong>
                            </div>
                            <div class="client-order-field">
                                <span>Entrega</span>
                                <strong>${new Date(order.deliveryDate).toLocaleDateString('es-CR')}</strong>
                            </div>
                            <div class="client-order-field">
                                <span>Método</span>
                                <strong>${order.paymentMethod || 'Pendiente'}</strong>
                            </div>
                            <div class="client-order-field">
                                <span>Total</span>
                                <strong>${app.utils.formatCurrency(order.total)}</strong>
                            </div>
                        </div>

                        <div class="client-order-bottom">
                            <div class="text-muted">${order.address}</div>
                            <div class="client-order-buttons">
                                ${order.paymentStatus !== 'Pagado' ? `<button class="btn btn-primary btn-sm" onclick="payClientOrder(${order.id})"><i class="fas fa-credit-card"></i> Pagar</button>` : ''}
                                <a class="btn btn-outline btn-sm" href="/Client/Track"><i class="fas fa-route"></i> Ver seguimiento</a>
                            </div>
                        </div>
                    </article>
                `).join('') || `
                    <div class="card client-empty-state">
                        <h3>No hay pedidos con esos filtros</h3>
                        <p class="text-muted">Prueba con otro estado o registra un pedido desde el panel del cliente.</p>
                        <a href="/Client" class="btn btn-primary"><i class="fas fa-plus"></i> Nuevo pedido</a>
                    </div>
                `;
            }

            window.payClientOrder = (id) => {
                selectedOrder = BakeSmartStore.orders.byClient(userEmail).find(order => Number(order.id) === Number(id));
                if (!selectedOrder) return;
                document.getElementById('ordersPaymentTitle').textContent = `Pagar pedido #${selectedOrder.id}`;
                document.getElementById('ordersPaymentTotal').textContent = app.utils.formatCurrency(selectedOrder.total);
                paymentModal.hidden = false;
            };

            function syncPaymentFields() {
                const isSinpe = paymentMethod.value === 'SINPE';
                document.querySelectorAll('#ordersPaymentModal .payment-card-field').forEach(field => {
                    field.hidden = isSinpe;
                });
            }

            function closePaymentModal() {
                paymentModal.hidden = true;
                selectedOrder = null;
                paymentForm.reset();
                syncPaymentFields();
            }

            document.querySelectorAll('[data-payment-close]').forEach(button => button.addEventListener('click', closePaymentModal));
            paymentMethod.addEventListener('change', syncPaymentFields);

            paymentForm.addEventListener('submit', async event => {
                event.preventDefault();
                if (!selectedOrder) return;

                const data = Object.fromEntries(new FormData(paymentForm).entries());
                if (data.method === 'Tarjeta') {
                    const digits = String(data.card || '').replace(/\D/g, '');
                    if (digits.length < 12 || !data.expiry || !data.cvv) {
                        app.toast.error('Complete los datos de tarjeta para simular el pago.');
                        return;
                    }
                }

                try {
                    paymentSubmit.disabled = true;
                    await BakeSmartStore.orders.markPaid(selectedOrder.id, data.method);
                    await BakeSmartStore.refresh();
                    app.toast.success('Pago registrado. Tu pedido fue enviado al flujo operativo.');
                    closePaymentModal();
                    render();
                } catch (error) {
                    app.toast.error(error.message);
                } finally {
                    paymentSubmit.disabled = false;
                }
            });

            search.addEventListener('input', render);
            statusFilter.addEventListener('change', render);
            BakeSmartStore.refresh().then(render).catch(error => app.toast.error(error.message));
        })();
    </script>
}
