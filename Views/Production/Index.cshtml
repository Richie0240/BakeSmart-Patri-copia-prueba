@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Produccion";
}

<div class="page-shell production-page">
    <div class="page-header production-header">
        <div>
            <h1 style="margin:0;display:flex;align-items:center;gap:.75rem;">
                <i class="fas fa-utensils" style="color:var(--primary);"></i>
                Produccion
            </h1>
            <p class="text-muted" style="margin:.35rem 0 0;">Cola de produccion y estado de pedidos.</p>
        </div>
        <span class="badge badge-info">
            <i class="fas fa-calendar-day"></i>
            @DateTime.Now.ToString("dddd, dd MMM", new System.Globalization.CultureInfo("es-ES"))
        </span>
    </div>

    <div class="production-content">
        <div class="grid grid-4 production-kpi-grid">
            <div class="card" style="text-align:center;">
                <i class="fas fa-clock" style="font-size:2rem;color:var(--warning);"></i>
                <div id="prodPendingCount" style="font-size:1.5rem;font-weight:700;">0</div>
                <div class="text-muted">Pendientes</div>
            </div>
            <div class="card" style="text-align:center;">
                <i class="fas fa-cog" style="font-size:2rem;color:var(--info);"></i>
                <div id="prodActiveCount" style="font-size:1.5rem;font-weight:700;">0</div>
                <div class="text-muted">En proceso</div>
            </div>
            <div class="card" style="text-align:center;">
                <i class="fas fa-check-circle" style="font-size:2rem;color:var(--success);"></i>
                <div id="prodDoneCount" style="font-size:1.5rem;font-weight:700;">0</div>
                <div class="text-muted">Completados</div>
            </div>
            <div class="card" style="text-align:center;">
                <i class="fas fa-exclamation-triangle" style="font-size:2rem;color:var(--danger);"></i>
                <div id="prodLateCount" style="font-size:1.5rem;font-weight:700;">0</div>
                <div class="text-muted">Atrasados</div>
            </div>
        </div>

        <div class="production-board">
            <div class="card production-lane production-lane--pending">
                <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
                    <h3 style="margin:0;"><span style="width:12px;height:12px;background:var(--warning);display:inline-block;border-radius:50%;margin-right:.5rem;"></span>Pendientes</h3>
                    <span id="prodPendingBadge" class="badge badge-warning">0</span>
                </div>
                <div id="prodPendingList" class="kanban-column" style="display:flex;flex-direction:column;gap:1rem;">
                    <div class="text-muted">Cargando pedidos...</div>
                </div>
            </div>

            <div class="card production-lane production-lane--active">
                <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
                    <h3 style="margin:0;"><span style="width:12px;height:12px;background:var(--info);display:inline-block;border-radius:50%;margin-right:.5rem;"></span>En produccion</h3>
                    <span id="prodActiveBadge" class="badge badge-info">0</span>
                </div>
                <div id="prodActiveList" class="kanban-column" style="display:flex;flex-direction:column;gap:1rem;">
                    <div class="text-muted">Cargando pedidos...</div>
                </div>
            </div>

            <div class="card production-lane production-lane--done">
                <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
                    <h3 style="margin:0;"><span style="width:12px;height:12px;background:var(--success);display:inline-block;border-radius:50%;margin-right:.5rem;"></span>Completados</h3>
                    <span id="prodDoneBadge" class="badge badge-success">0</span>
                </div>
                <div id="prodDoneList" style="display:flex;flex-direction:column;gap:1rem;">
                    <div class="text-muted">Cargando pedidos...</div>
                </div>
            </div>
        </div>

        <div class="card production-schedule-card">
            <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;">
                <h3 style="margin:0;display:flex;align-items:center;gap:.5rem;">
                    <i class="fas fa-clock" style="color:var(--primary);"></i>
                    Programacion del dia
                </h3>
                <span class="badge badge-info">@DateTime.Now.ToString("dd/MM/yyyy")</span>
            </div>
            <div id="productionSchedule" style="display:flex;flex-direction:column;gap:1rem;">
                <div class="text-muted">Cargando programacion...</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
    const store = window.BakeSmartStore;
    const today = new Date();
    today.setHours(0, 0, 0, 0);

    const statusMeta = {
        'Pendiente pago': { badge: 'badge-warning', border: 'var(--warning)', next: 'Confirmado', action: 'Cobrar', icon: 'fa-money-bill-wave', progress: 10 },
        'Confirmado': { badge: 'badge-info', border: 'var(--info)', next: 'En produccion', action: 'Iniciar', icon: 'fa-play', progress: 25 },
        'En produccion': { badge: 'badge-primary', border: 'var(--primary)', next: 'Listo', action: 'Listo', icon: 'fa-arrow-right', progress: 60 },
        'En producción': { badge: 'badge-primary', border: 'var(--primary)', next: 'Listo', action: 'Listo', icon: 'fa-arrow-right', progress: 60 },
        'Listo': { badge: 'badge-success', border: 'var(--success)', next: 'En camino', action: 'Enviar', icon: 'fa-truck', progress: 82 },
        'En camino': { badge: 'badge-info', border: 'var(--info)', next: 'Entregado', action: 'Entregar', icon: 'fa-check', progress: 92 },
        'Entregado': { badge: 'badge-success', border: 'var(--success)', next: '', action: '', icon: 'fa-check', progress: 100 }
    };

    const setText = (id, value) => {
        const el = document.getElementById(id);
        if (el) el.textContent = value;
    };

    const fmtDate = value => new Date(value).toLocaleDateString('es-CR', { day: '2-digit', month: '2-digit' });
    const statusOf = order => order.estado || order.status || '';
    const customerOf = order => order.cliente || order.customerName || '-';
    const deliveryOf = order => order.entrega || order.deliveryDate || new Date().toISOString();
    const itemOf = order => order.producto || order.products || 'Pedido personalizado';

    function ticket(order, mode) {
        const status = statusOf(order);
        const meta = statusMeta[status] || statusMeta.Confirmado;
        const action = status === 'Pendiente pago'
            ? `<button class="btn btn-primary btn-sm" onclick="chargeProductionOrder(${order.id})"><i class="fas fa-money-bill-wave"></i> Cobrar</button>`
            : status !== 'Entregado'
            ? `<button class="btn btn-primary btn-sm" onclick="moveProductionOrder(${order.id}, '${meta.next}')"><i class="fas ${meta.icon}"></i> ${meta.action}</button>`
            : `<span class="badge badge-success">Completado</span>`;

        return `
            <div class="card production-ticket" style="border-left:4px solid ${meta.border};">
                <div style="display:flex;justify-content:space-between;gap:.75rem;margin-bottom:.5rem;align-items:start;">
                    <strong>#${order.id} - ${customerOf(order)}</strong>
                    <span class="badge ${meta.badge}">${status}</span>
                </div>
                <div>${itemOf(order)}</div>
                ${mode !== 'pending' ? `<div class="progress" style="margin:.65rem 0;"><div class="progress-bar" style="width:${meta.progress}%;"></div></div>` : ''}
                <div style="display:flex;justify-content:space-between;align-items:center;gap:.75rem;margin-top:.65rem;">
                    <span class="text-muted"><i class="fas fa-calendar"></i> ${fmtDate(deliveryOf(order))}</span>
                    ${action}
                </div>
            </div>`;
    }

    function scheduleRow(order, index) {
        const hour = `${8 + index}:00`;
        return `
            <div class="production-schedule-row">
                <div class="production-schedule-time">${hour}</div>
                <div class="production-schedule-line"><span style="left:${Math.min(index * 18, 90)}%;"></span></div>
                <div class="production-schedule-label">#${order.id} - ${itemOf(order)}</div>
            </div>`;
    }

    function renderProduction() {
        const orders = store.orders.list();
        const pending = orders.filter(o => ['Pendiente pago', 'Confirmado'].includes(statusOf(o)));
        const active = orders.filter(o => ['En produccion', 'En producción', 'Listo', 'En camino'].includes(statusOf(o)));
        const done = orders.filter(o => statusOf(o) === 'Entregado');
        const late = orders.filter(o => {
            const delivery = new Date(deliveryOf(o));
            delivery.setHours(0, 0, 0, 0);
            return delivery < today && statusOf(o) !== 'Entregado';
        });

        setText('prodPendingCount', pending.length);
        setText('prodActiveCount', active.length);
        setText('prodDoneCount', done.length);
        setText('prodLateCount', late.length);
        setText('prodPendingBadge', pending.length);
        setText('prodActiveBadge', active.length);
        setText('prodDoneBadge', done.length);

        document.getElementById('prodPendingList').innerHTML = pending.map(o => ticket(o, 'pending')).join('') || '<div class="text-muted">No hay pedidos pendientes.</div>';
        document.getElementById('prodActiveList').innerHTML = active.map(o => ticket(o, 'active')).join('') || '<div class="text-muted">No hay pedidos en produccion.</div>';
        document.getElementById('prodDoneList').innerHTML = done.map(o => ticket(o, 'done')).join('') || '<div class="text-muted">No hay pedidos completados.</div>';
        document.getElementById('productionSchedule').innerHTML = orders.slice(0, 5).map(scheduleRow).join('') || '<div class="text-muted">No hay programacion para hoy.</div>';
    }

    window.moveProductionOrder = (orderId, nextStatus) => {
        store.orders.updateStatus(orderId, nextStatus).then(() => {
            renderProduction();
            app.toast.success(`Pedido #${orderId} actualizado.`);
        }).catch(error => app.toast.error(error.message));
    };

    window.chargeProductionOrder = (orderId) => {
        const order = store.orders.list().find(item => Number(item.id) === Number(orderId));
        if (!order) {
            app.toast.error('No se encontro el pedido para cobrar.');
            return;
        }

        const product = store.inventory.list().find(item => Number(item.id) === Number(order.productId));
        const cartItem = {
            productId: Number(order.productId),
            name: product?.description || product?.item || order.producto || 'Pedido',
            code: product?.code || product?.sku || `PED-${order.id}`,
            unitPrice: Number(order.unitPrice || product?.price || order.total || 0),
            quantity: Number(order.quantity || 1)
        };

        sessionStorage.setItem('bakesmart.pos.pendingOrder', JSON.stringify({
            id: order.id,
            customerName: order.customerName || order.cliente || '',
            customerEmail: order.customerEmail || '',
            paymentMethod: order.paymentMethod || 'Tarjeta',
            total: Number(order.total || 0),
            item: cartItem
        }));
        sessionStorage.setItem('bakesmart.pos.cart', JSON.stringify([cartItem]));
        window.location.assign('/Pos/Cart?orderId=' + encodeURIComponent(order.id));
    };

    store.refresh().then(renderProduction).catch(error => app.toast.error(error.message));
})();
</script>
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/production-index.css" asp-append-version="true" />
}
