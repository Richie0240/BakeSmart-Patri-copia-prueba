@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Inventario";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/inventory-index.css" asp-append-version="true" />
}

<div class="page-shell inventory-page">
    <div class="page-header inventory-header">
        <div>
            <h1 class="inventory-title">
                <i class="fas fa-boxes-stacked"></i>
                Inventario operativo
            </h1>
            <p class="text-muted inventory-subtitle">
                Materias primas, empaques y movimientos. Los queques, galletas y cupcakes se administran en Productos vendibles.
            </p>
        </div>

        <div class="page-actions inventory-actions">
            <input id="inventorySearch" class="form-control" placeholder="Buscar por cÃ³digo o descripciÃ³n" />
            <select id="inventoryTypeFilter" class="form-control inventory-type-filter">
                <option value="todos">Todo el inventario</option>
                <option value="operativo">Materia prima / empaque</option>
                <option value="Producto terminado">Productos vendibles</option>
                <option value="Materia prima">Solo materia prima</option>
                <option value="Empaque">Solo empaques</option>
            </select>
            <select id="inventoryCategory" class="form-control inventory-category"></select>
            <select id="inventoryStockFilter" class="form-control inventory-stock-filter">
                <option value="todas">Todo el stock</option>
                <option value="bajo">Stock bajo (&lt;= minimo)</option>
                <option value="critico">Stock crÃ­tico (= 0)</option>
                <option value="disponible">Con stock (&gt; 0)</option>
            </select>
            <a class="btn btn-outline" href="/Inventory/Products">
                <i class="fas fa-cake-candles"></i>
                Productos vendibles
            </a>
            <button type="button" id="inventoryQuickActions" class="btn btn-primary">
                <i class="fas fa-bolt"></i>
                Nueva materia prima
            </button>
            <button type="button" id="inventoryMovementActions" class="btn btn-outline">
                <i class="fas fa-right-left"></i>
                Movimiento
            </button>
        </div>
    </div>

    <div class="grid grid-4 inventory-kpi-grid">
        <div class="card inventory-kpi-card">
            <div class="text-muted">Items</div>
            <h2 id="invTotal"></h2>
        </div>
        <div class="card inventory-kpi-card">
            <div class="text-muted">Activos</div>
            <h2 id="invActive"></h2>
        </div>
        <div class="card inventory-kpi-card">
            <div class="text-muted">Stock bajo</div>
            <h2 id="invLow"></h2>
        </div>
        <div class="card inventory-kpi-card">
            <div class="text-muted">Materia prima</div>
            <h2 id="invRaw"></h2>
        </div>
    </div>

    <div class="card inventory-presets-card">
        <div class="inventory-panel-header">
            <div>
                <h3 class="inventory-panel-title">Alta rapida de materia prima</h3>
                <p class="text-muted" style="margin:.35rem 0 0;">Plantillas comunes para registrar inventario real de reposteria.</p>
            </div>
        </div>
        <div class="inventory-preset-grid">
            <button type="button" class="inventory-preset-btn" onclick="openIngredientPreset('MP-HAR-', 'Harina pastelera', 'Secos', 'kg', 25, 15, 950)">
                <i class="fas fa-wheat-awn"></i><span>Harina</span><small>kg</small>
            </button>
            <button type="button" class="inventory-preset-btn" onclick="openIngredientPreset('MP-AZU-', 'Azucar blanca', 'Secos', 'kg', 20, 10, 780)">
                <i class="fas fa-cubes-stacked"></i><span>Azucar</span><small>kg</small>
            </button>
            <button type="button" class="inventory-preset-btn" onclick="openIngredientPreset('MP-MAN-', 'Mantequilla sin sal', 'Lacteos', 'kg', 8, 5, 4200)">
                <i class="fas fa-cheese"></i><span>Mantequilla</span><small>kg</small>
            </button>
            <button type="button" class="inventory-preset-btn" onclick="openIngredientPreset('EMP-CAJ-', 'Caja para entregas', 'Cajas', 'unidad', 50, 20, 420, 'Empaque', 'Empaques')">
                <i class="fas fa-box"></i><span>Cajas</span><small>unidad</small>
            </button>
        </div>
    </div>

    <template id="inventoryProductTemplate">
        <div class="inventory-modal-shell">
            <div class="inventory-modal-head">
                <h3 class="inventory-modal-title">Materia prima o empaque</h3>
            </div>

            <form id="inventoryForm" class="inventory-modal-form">
                <input type="hidden" name="id" />

                <div>
                    <label>Codigo</label>
                    <input class="form-control" name="code" required />
                </div>

                <div>
                    <label>Precio o costo</label>
                    <input class="form-control" name="price" type="number" min="0" step="0.01" required />
                </div>

                <div>
                    <label>Tipo</label>
                    <select class="form-control" name="type">
                        <option>Materia prima</option>
                        <option>Producto terminado</option>
                        <option>Empaque</option>
                        <option>Insumo operativo</option>
                    </select>
                </div>

                <div>
                    <label>Unidad</label>
                    <select class="form-control" name="unit">
                        <option>kg</option>
                        <option>g</option>
                        <option>L</option>
                        <option>ml</option>
                        <option>unidad</option>
                        <option>caja</option>
                        <option>paquete</option>
                    </select>
                </div>

                <div class="inventory-modal-full">
                    <label>Descripcion</label>
                    <input class="form-control" name="description" required />
                </div>

                <div>
                    <label>Categoria</label>
                    <input class="form-control" name="category" required />
                </div>

                <div>
                    <label>Subcategoria</label>
                    <input class="form-control" name="subcategory" />
                </div>

                <div>
                    <label>Cantidad</label>
                    <input class="form-control" name="stock" type="number" min="0" step="0.01" required />
                </div>

                <div>
                    <label>Stock minimo</label>
                    <input class="form-control" name="minStock" type="number" min="0" step="0.01" value="5" required />
                </div>

                <div class="inventory-modal-actions inventory-modal-full">
                    <button class="btn btn-primary" type="submit">
                        <i class="fas fa-save"></i>
                        Guardar inventario
                    </button>
                </div>
            </form>
        </div>
    </template>

    <template id="inventoryMovementTemplate">
        <div class="inventory-modal-shell">
            <div class="inventory-modal-head">
                <h3 class="inventory-modal-title">Movimiento rÃ¡pido</h3>
            </div>

            <form id="movementForm" class="inventory-modal-form">
                <div class="inventory-modal-full">
                    <label>Producto</label>
                    <select class="form-control" name="productId" id="movementProduct"></select>
                </div>

                <div>
                    <label>Tipo</label>
                    <select class="form-control" name="type">
                        <option value="ENTRADA">Entrada</option>
                        <option value="SALIDA">Salida</option>
                        <option value="AJUSTE">Ajuste positivo</option>
                    </select>
                </div>

                <div>
                    <label>Cantidad</label>
                    <input class="form-control" name="quantity" type="number" min="0.01" step="0.01" placeholder="Cantidad" required />
                </div>

                <div class="inventory-modal-full">
                    <label>Nota</label>
                    <input class="form-control" name="note" placeholder="Nota" />
                </div>

                <div class="inventory-modal-actions inventory-modal-full">
                    <button class="btn btn-primary" type="submit">
                        <i class="fas fa-check-circle"></i>
                        Registrar movimiento
                    </button>
                </div>
            </form>
        </div>
    </template>

    <div class="card inventory-products-card">
        <div class="inventory-panel-header">
            <div>
                <h3 class="inventory-panel-title">Inventario operativo</h3>
            </div>
        </div>

        <div class="table-container inventory-table-wrap">
            <table class="table inventory-table inventory-products-table">
                <thead>
                    <tr>
                        <th>Codigo</th>
                        <th>Descripcion</th>
                        <th>Tipo</th>
                        <th>Categoria</th>
                        <th>Costo / precio</th>
                        <th>Cantidad</th>
                        <th>Minimo</th>
                        <th>Estado</th>
                        <th class="text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody id="inventoryTable"></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const search = document.getElementById('inventorySearch');
            const typeFilter = document.getElementById('inventoryTypeFilter');
            const category = document.getElementById('inventoryCategory');
            const stockFilter = document.getElementById('inventoryStockFilter');
            const quickButton = document.getElementById('inventoryQuickActions');
            const movementButton = document.getElementById('inventoryMovementActions');
            let products = [];
            let movements = [];
            let categoriesInitialized = false;

            function normalizeProduct(p) {
                return {
                    id: Number(p.id),
                    code: p.sku || p.code || '',
                    description: p.item || p.description || '',
                    type: p.type || 'Producto terminado',
                    unit: p.unidad || p.unit || 'unidad',
                    category: p.category || 'General',
                    subcategory: p.subcategory || '',
                    price: Number(p.price || p.costo || 0),
                    stock: Number(p.stock || 0),
                    minStock: Number(p.min || p.minStock || 0),
                    active: Boolean(p.active)
                };
            }

            async function postJson(url, payload = {}) {
                const response = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (!response.ok) {
                    let message = 'No se pudo guardar la informaciÃ³n.';
                    try {
                        const error = await response.json();
                        message = error.message || message;
                    } catch { }
                    throw new Error(message);
                }

                return response.json();
            }

            async function loadInventory() {
                products = (await fetch('/api/inventory').then(r => r.json())).map(normalizeProduct);
                movements = await fetch('/api/inventory/movements').then(r => r.json());
            }

            function getCategories() {
                return ['Todas', ...new Set(products.map(p => p.category).filter(Boolean))];
            }

            function initializeCategories() {
                if (categoriesInitialized) return;
                const available = getCategories();
                category.innerHTML = available.map(c => `<option value="${c}">${c}</option>`).join('');
                category.value = 'Todas';
                categoriesInitialized = true;
            }

            function refreshCategoriesIfNeeded() {
                const available = getCategories();
                const currentOptions = Array.from(category.options).map(o => o.value);

                if (available.join('|') !== currentOptions.join('|')) {
                    const selected = category.value || 'Todas';
                    category.innerHTML = available.map(c => `<option value="${c}">${c}</option>`).join('');
                    category.value = available.includes(selected) ? selected : 'Todas';
                }
            }

            function bindProductForm() {
                const form = document.getElementById('inventoryForm');
                if (!form) return;

                form.addEventListener('submit', async (event) => {
                    event.preventDefault();
                    const data = Object.fromEntries(new FormData(form).entries());
                    const payload = {
                        id: data.id ? Number(data.id) : null,
                        code: data.code,
                        description: data.description,
                        type: data.type,
                        unit: data.unit,
                        category: data.category,
                        subcategory: data.subcategory || null,
                        price: Number(data.price || 0),
                        stock: Number(data.stock || 0),
                        minStock: Number(data.minStock || 0)
                    };

                    try {
                        await postJson('/api/inventory', payload);
                        app.toast.success('Inventario guardado en SQL.');
                        app.modal.close();
                        await refreshAll();
                    } catch (error) {
                        app.toast.error(error.message);
                    }
                });
            }

            function bindMovementForm() {
                const movementForm = document.getElementById('movementForm');
                const movementProduct = document.getElementById('movementProduct');
                if (!movementForm || !movementProduct) return;

                movementProduct.innerHTML = products
                    .map(p => `<option value="${p.id}">${p.code} - ${p.description} (${p.stock} ${p.unit || 'unidad'})</option>`)
                    .join('');

                movementForm.addEventListener('submit', async (event) => {
                    event.preventDefault();
                    const data = Object.fromEntries(new FormData(movementForm).entries());
                    const payload = {
                        productId: Number(data.productId),
                        type: data.type,
                        quantity: Number(data.quantity || 0),
                        note: data.note || null
                    };

                    try {
                        await postJson('/api/inventory/movements', payload);
                        app.toast.success('Movimiento registrado en SQL.');
                        app.modal.close();
                        await refreshAll();
                    } catch (error) {
                        app.toast.error(error.message);
                    }
                });
            }

            function renderProducts() {
                const all = products;
                document.getElementById('invTotal').textContent = all.length;
                document.getElementById('invActive').textContent = all.filter(x => x.active).length;
                document.getElementById('invLow').textContent = all.filter(x => Number(x.stock) <= Number(x.minStock ?? 5)).length;
                document.getElementById('invRaw').textContent = all.filter(x => x.type === 'Materia prima').length;

                refreshCategoriesIfNeeded();
                const query = search.value.trim().toLowerCase();
                const selectedCategory = category.value || 'Todas';
                const selectedType = typeFilter?.value || 'todos';
                const selectedStock = stockFilter?.value || 'todas';
                const rows = all.filter(p => {
                    const stockNum = Number(p.stock);
                    const minNum = Number(p.minStock ?? 5);
                    const matchesQuery = !query || p.code.toLowerCase().includes(query) || p.description.toLowerCase().includes(query);
                    const matchesCategory = selectedCategory === 'Todas' || p.category === selectedCategory;
                    let matchesType = true;
                    if (selectedType === 'operativo') matchesType = p.type !== 'Producto terminado';
                    else if (selectedType !== 'todos') matchesType = p.type === selectedType;
                    let matchesStock = true;
                    if (selectedStock === 'bajo') matchesStock = stockNum <= minNum;
                    else if (selectedStock === 'critico') matchesStock = stockNum === 0;
                    else if (selectedStock === 'disponible') matchesStock = stockNum > 0;
                    return matchesQuery && matchesCategory && matchesType && matchesStock;
                });

                document.getElementById('inventoryTable').innerHTML = rows.map(p => {
                    const stockNum = Number(p.stock);
                    const minNum = Number(p.minStock ?? 5);
                    const stockPct = Math.min(100, Math.round((stockNum / Math.max(stockNum, minNum * 2)) * 100));
                    const isLow = stockNum <= minNum;
                    const stockColor = stockNum === 0 ? 'var(--danger)' : isLow ? 'var(--warning)' : 'var(--success)';
                    return `
                    <tr class="${stockNum === 0 ? 'inv-row-danger' : isLow ? 'inv-row-warning' : ''}">
                        <td><strong style="color:var(--primary);font-size:.85rem;">${p.code}</strong></td>
                        <td>
                            <strong style="font-size:.92rem;">${p.description}</strong>
                            <div class="text-muted" style="font-size:.75rem;">${p.subcategory || 'Sin subcategorÃ­a'} Â· ${p.unit || 'unidad'}</div>
                        </td>
                        <td><span class="inventory-type-chip">${p.type}</span></td>
                        <td><span style="font-size:.85rem;">${p.category}</span></td>
                        <td style="font-weight:700;color:var(--primary);">${app.utils.formatCurrency(p.price)}</td>
                        <td>
                            <div style="display:flex;align-items:center;gap:.5rem;">
                                <div style="flex:1;max-width:60px;height:6px;border-radius:999px;background:var(--border);overflow:hidden;">
                                    <div style="width:${stockPct}%;height:100%;border-radius:999px;background:${stockColor};transition:width .4s ease;"></div>
                                </div>
                                <span class="badge ${stockNum === 0 ? 'badge-danger' : isLow ? 'badge-warning' : 'badge-success'}" style="font-size:.75rem;">${p.stock}</span>
                            </div>
                        </td>
                        <td style="color:var(--text-muted);font-size:.85rem;">${p.minStock ?? 5}</td>
                        <td>
                            <span class="badge ${p.active ? 'badge-success' : 'badge-warning'}" style="font-size:.72rem;">
                                ${p.active ? 'Activo' : 'Inactivo'}
                            </span>
                        </td>
                        <td class="text-right inventory-row-actions">
                            <button class="btn btn-outline btn-sm" onclick="editProduct(${p.id})" style="font-size:.75rem;"><i class="fas fa-pen"></i></button>
                            <button class="btn btn-ghost btn-sm" onclick="toggleProduct(${p.id})" style="color:${p.active ? 'var(--warning)' : 'var(--success)'};font-size:.75rem;">
                                ${p.active ? '<i class="fas fa-pause"></i>' : '<i class="fas fa-play"></i>'}
                            </button>
                        </td>
                    </tr>
                `}).join('') || `
                    <tr>
                        <td colspan="9" class="text-center text-muted">No hay productos para mostrar.</td>
                    </tr>
                `;
            }

            async function refreshAll() {
                await loadInventory();
                renderProducts();
            }

            window.openInventoryQuickActions = (section = 'product') => {
                const templates = {
                    product: { title: 'Materia prima o empaque', selector: '#inventoryProductTemplate', maxWidth: '980px' },
                    movement: { title: 'Movimiento', selector: '#inventoryMovementTemplate', maxWidth: '980px' }
                };

                const selected = templates[section] || templates.product;
                const template = document.querySelector(selected.selector);
                app.modal.open({
                    title: selected.title,
                    maxWidth: selected.maxWidth,
                    content: template ? template.innerHTML : ''
                });

                if (section === 'product') bindProductForm();
                if (section === 'movement') bindMovementForm();
            };

            window.editProduct = (id) => {
                openInventoryQuickActions('product');
                const item = products.find(x => x.id === id);
                const form = document.getElementById('inventoryForm');
                if (!item || !form) return;

                for (const [key, value] of Object.entries(item)) {
                    const input = form.querySelector(`[name="${key}"]`);
                    if (input) input.value = value;
                }
            };

            window.openIngredientPreset = (codePrefix, description, subcategory, unit, stock, minStock, price, type = 'Materia prima', categoryName = 'Ingredientes') => {
                openInventoryQuickActions('product');
                const form = document.getElementById('inventoryForm');
                if (!form) return;

                const next = String(Date.now()).slice(-3);
                form.code.value = `${codePrefix}${next}`.toUpperCase();
                form.description.value = description;
                form.type.value = type;
                form.unit.value = unit;
                form.category.value = categoryName;
                form.subcategory.value = subcategory;
                form.price.value = price;
                form.stock.value = stock;
                form.minStock.value = minStock;
            };

            window.toggleProduct = async (id) => {
                try {
                    await postJson(`/api/inventory/${id}/toggle`);
                    app.toast.success('Estado del producto actualizado.');
                    await refreshAll();
                } catch (error) {
                    app.toast.error(error.message);
                }
            };

            quickButton.addEventListener('click', () => openInventoryQuickActions('product'));
            movementButton.addEventListener('click', () => openInventoryQuickActions('movement'));
            search.addEventListener('input', renderProducts);
            if (typeFilter) typeFilter.addEventListener('change', renderProducts);
            category.addEventListener('change', renderProducts);
            if (stockFilter) stockFilter.addEventListener('change', renderProducts);
            refreshAll().then(initializeCategories).catch(error => app.toast.error(error.message));
        })();
    </script>
}

