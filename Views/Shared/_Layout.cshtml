@{
    var title = ViewData["Title"] as string ?? "BakeSmart Patri";
    var isAuth = User?.Identity?.IsAuthenticated ?? false;
    var isAdmin = User?.IsInRole("Admin") ?? false;
    var isStaff = User?.IsInRole("Staff") ?? false;
    var isClient = User?.IsInRole("Cliente") ?? false;
    var isCashier = User?.IsInRole("Cajero") ?? false;
    var isBaker = User?.IsInRole("Repostero") ?? false;
    var isSupervisor = User?.IsInRole("Supervisor") ?? false;
    var isOperational = isAdmin || isStaff || isCashier || isBaker || isSupervisor;

    string userInitials = "U";
    string userName = "Usuario";
    string userRoleLabel = isAdmin ? "Administrador"
        : isStaff ? "Staff"
        : isCashier ? "Cajero"
        : isBaker ? "Repostero"
        : isSupervisor ? "Supervisor"
        : "Cliente";

    if (isAuth && User?.Identity?.Name != null)
    {
        userName = User.Identity.Name;
        var names = userName.Split(' ');
        userInitials = names.Length > 0 ? names[0].Substring(0, 1).ToUpper() : "U";
        if (names.Length > 1) userInitials += names[1].Substring(0, 1).ToUpper();
    }

    var currentPath = Context.Request.Path.ToString().ToLower();
    var showStorefrontHeader = !isAuth || isClient;
    var enablePageLoader = false;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - BakeSmart Patri | Repostería Inteligente</title>
    <meta name="description" content="BakeSmart Patri - Sistema de gestión para reposterías. Pedidos, producción, inventario y más." />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script>
        try {
            const savedTheme = localStorage.getItem('bakesmart.theme');
            const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
            if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
                document.documentElement.classList.add('dark-start');
            }
        } catch (_) { }
    </script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <link rel="stylesheet" href="~/css/global/workspace-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/global/smart-tables.css" asp-append-version="true" />
    <style>
        
        @@keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        @@keyframes slideOut {
            from {
                transform: translateX(0);
                opacity: 1;
            }

            to {
                transform: translateX(100%);
                opacity: 0;
            }
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        @@keyframes fadeOut {
            from {
                opacity: 1;
            }

            to {
                opacity: 0;
            }
        }

        
        .dark-mode-script {
            display: none;
        }
    </style>
</head>
<body class="app-body page-ready" data-page="@currentPath" data-user-email="@(User?.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "")">
    @if (enablePageLoader)
    {
        <div id="pageLoader" class="page-loader" aria-hidden="true">
            <div class="page-loader__content">
                <div class="loader-badge">
                    <span class="loader-gear loader-gear--lg"><i class="fas fa-gear"></i></span>
                    <span class="loader-gear loader-gear--sm"><i class="fas fa-cake-candles"></i></span>
                </div>
                <div class="page-loader__title">BakeSmart Patri</div>
                <div class="page-loader__text">Preparando una experiencia más dinámica…</div>
            </div>
        </div>
    }

    <div class="app-background" aria-hidden="true">
        <span class="bg-orb bg-orb--one"></span>
        <span class="bg-orb bg-orb--two"></span>
        <span class="bg-orb bg-orb--three"></span>
        <div class="bg-grid"></div>
        <div class="bg-floating-icons">
            <i class="fas fa-gear gear-float gear-float--one"></i>
            <i class="fas fa-cookie-bite gear-float gear-float--two"></i>
            <i class="fas fa-cake-candles gear-float gear-float--three"></i>
            <i class="fas fa-chart-pie gear-float gear-float--four"></i>
        </div>
        <div id="bgParticles" class="bg-particles"></div>
    </div>

    <div class="cursor-glow" aria-hidden="true"></div>
    
    @if (showStorefrontHeader)
    {
        <header class="storefront-header">
            <div class="storefront-promo"><i class="fas fa-sparkles"></i> Sabor artesanal para todos tus momentos especiales</div>
            <div class="storefront-main container">
                <a class="storefront-brand" href="/">
                    <img src="~/img/logo.png" alt="BakeSmart Patri" />
                    <span>BakeSmart <strong>Patri</strong></span>
                </a>
                <form class="storefront-search" action="/Catalog" method="get" role="search">
                    <input name="search" type="search" aria-label="Buscar productos" placeholder="¿Qué postre se te antoja hoy?" />
                    <button type="submit" aria-label="Buscar"><i class="fas fa-search"></i></button>
                </form>
                <div class="storefront-tools">
                    @if (isAuth)
                    {
                        <a href="/Account/Profile"><i class="far fa-user"></i><span>Mi cuenta</span></a>
                        <a href="/Client/Orders"><i class="fas fa-box"></i><span>Pedidos</span></a>
                    }
                    else
                    {
                        <a href="/Account/Login"><i class="far fa-user"></i><span>Mi cuenta</span></a>
                        <a href="/Catalog"><i class="far fa-heart"></i><span>Favoritos</span></a>
                    }
                    <a href="/Catalog?cart=open"><i class="fas fa-cart-shopping"></i><span>Carrito</span></a>
                    <button class="storefront-theme theme-toggle" type="button" onclick="window.app.theme.toggle()" aria-label="Cambiar tema"><i class="fas fa-moon"></i></button>
                </div>
            </div>
            <nav class="storefront-nav" aria-label="Navegación principal">
                <div class="container storefront-nav-inner">
                    <a class="storefront-category-link" href="/Catalog/Categories"><i class="fas fa-bars"></i> Todas las categorías</a>
                    <div class="storefront-nav-links">
                        <a href="/">Inicio</a><a href="/Catalog">Productos</a><a href="/Catalog/Offers">Ofertas</a><a href="/Catalog/New">Novedades</a><a href="/Catalog/Combos">Combos</a><a href="/Home/About">Nosotros</a><a href="/Home/Contact">Contacto</a>
                        @if (isClient) { <a href="/Client">Mi panel</a> }
                    </div>
                </div>
            </nav>
        </header>
    }
    else
    {
    <nav class="navbar">
        <div class="navbar-container">
            <div class="navbar-brand">
                <div class="navbar-logo">
                    <img src="~/img/logo.png" alt="BakeSmart Patri" onerror="this.style.display='none'" />
                </div>
                <span class="navbar-brand-text" style="font-weight: 700; font-size: 1.25rem; background: linear-gradient(135deg, var(--primary), var(--secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">BakeSmart Patri</span>
            </div>

            <button type="button" class="mobile-nav-toggle" aria-controls="navbarMenu" aria-expanded="false" aria-label="Abrir navegación">
                <i class="fas fa-bars"></i>
            </button>

            <div class="navbar-menu" id="navbarMenu">
                @if (!isAuth || isClient)
                {
                    <a class="navbar-link" data-nav href="/">
                        <i class="fas fa-home" style="margin-right: 0.25rem;"></i> Inicio
                    </a>
                    <a class="navbar-link" data-nav href="/Catalog">
                        <i class="fas fa-cake-candles" style="margin-right: 0.25rem;"></i> Catálogo
                    </a>
                    <a class="navbar-link" data-nav href="/Home/About">
                        <i class="fas fa-heart" style="margin-right: 0.25rem;"></i> Sobre nosotros
                    </a>
                    <a class="navbar-link" data-nav href="/Home/Contact">
                        <i class="fas fa-location-dot" style="margin-right: 0.25rem;"></i> Contacto
                    </a>
                }

                @if (isAuth && isClient)
                {
                    <a class="navbar-link" data-nav href="/Client">
                        <i class="fas fa-user" style="margin-right: 0.25rem;"></i> Mi Panel
                    </a>
                    <a class="navbar-link" data-nav href="/Client/Orders">
                        <i class="fas fa-box" style="margin-right: 0.25rem;"></i> Mis Pedidos
                    </a>
                }

                @if (isAuth && isOperational)
                {
                    <a class="navbar-link" data-nav href="/Dashboard">
                        <i class="fas fa-chart-line" style="margin-right: 0.25rem;"></i> Dashboard
                    </a>

                    <div class="dropdown">
                        <span class="dropdown-toggle">
                            <i class="fas fa-store" style="margin-right: 0.25rem;"></i> Operación
                            <i class="fas fa-chevron-down" style="font-size: 0.75rem; margin-left: 0.25rem;"></i>
                        </span>
                        <div class="dropdown-menu">
                            @if (isAdmin || isStaff || isSupervisor || isCashier)
                            {
                                <a class="dropdown-item" href="/Orders">
                                    <i class="fas fa-clipboard-list" style="width: 20px; margin-right: 0.5rem;"></i> Pedidos
                                </a>
                            }
                            @if (isAdmin || isStaff || isSupervisor || isBaker)
                            {
                                <a class="dropdown-item" href="/Production">
                                    <i class="fas fa-utensils" style="width: 20px; margin-right: 0.5rem;"></i> Producción
                                </a>
                            }
                            @if (isAdmin || isStaff || isSupervisor || isBaker)
                            {
                                <a class="dropdown-item" href="/Inventory">
                                    <i class="fas fa-boxes" style="width: 20px; margin-right: 0.5rem;"></i> Inventario
                                </a>
                            }
                            @if (isAdmin || isStaff || isSupervisor || isCashier)
                            {
                                <a class="dropdown-item" href="/Pos">
                                    <i class="fas fa-cash-register" style="width: 20px; margin-right: 0.5rem;"></i> Punto de Venta
                                </a>
                            }
                            @if (isAdmin || isSupervisor)
                            {
                                <a class="dropdown-item" href="/Reports">
                                    <i class="fas fa-chart-bar" style="width: 20px; margin-right: 0.5rem;"></i> Reportes
                                </a>
                            }
                            @if (isAdmin || isStaff || isSupervisor)
                            {
                                <a class="dropdown-item" href="/Audit">
                                    <i class="fas fa-clock-rotate-left" style="width: 20px; margin-right: 0.5rem;"></i> Bitacora
                                </a>
                            }
                            @if (isAdmin)
                            {
                                <div style="border-top: 1px solid var(--border); margin: 0.5rem 0;"></div>
                                <a class="dropdown-item" href="/Users">
                                    <i class="fas fa-users" style="width: 20px; margin-right: 0.5rem;"></i> Usuarios
                                </a>
                                <a class="dropdown-item" href="/Roles">
                                    <i class="fas fa-shield" style="width: 20px; margin-right: 0.5rem;"></i> Roles
                                </a>
                                <a class="dropdown-item" href="/Accounting">
                                    <i class="fas fa-calculator" style="width: 20px; margin-right: 0.5rem;"></i> Contabilidad
                                </a>
                                <a class="dropdown-item" href="/Marketing">
                                    <i class="fas fa-megaphone" style="width: 20px; margin-right: 0.5rem;"></i> Marketing
                                </a>
                                <div style="border-top: 1px solid var(--border); margin: 0.5rem 0;"></div>
                                <a class="dropdown-item" href="/Admin/Settings">
                                    <i class="fas fa-cog" style="width: 20px; margin-right: 0.5rem;"></i> Configuración
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="navbar-actions">
                <button class="btn btn-ghost btn-sm theme-toggle" onclick="window.app.theme.toggle()" style="border-radius: 50%; width: 40px; height: 40px; padding: 0;">
                    <i class="fas fa-moon"></i>
                </button>

                @if (isAuth)
                {
                    <div class="user-menu" id="userMenu">
                        <button type="button" class="user-profile" id="userMenuToggle" aria-haspopup="true" aria-expanded="false">
                            <span class="user-avatar">@userInitials</span>
                            <span class="user-info">
                                <span class="user-name">@userName</span>
                                @if (!isClient)
                                {
                                    <span class="user-role">@userRoleLabel</span>
                                }
                                else
                                {
                                    <span class="user-role">Mi cuenta</span>
                                }
                            </span>
                            <span class="user-chevron"><i class="fas fa-chevron-down"></i></span>
                        </button>

                        <div class="user-dropdown" id="userDropdown" role="menu" hidden>
                            <div class="user-dropdown-head">
                                <span class="user-avatar user-avatar-sm">@userInitials</span>
                                <span>
                                    <strong>@userName</strong>
                                    <small>@(isClient ? "Perfil de cliente" : userRoleLabel)</small>
                                </span>
                            </div>

                            <a class="user-dropdown-item" href="/Account/Profile" role="menuitem">
                                <i class="fas fa-user-pen"></i>
                                <span>Mi perfil</span>
                            </a>

                            <div class="user-dropdown-divider"></div>

                            <form method="post" action="/Account/Logout" class="user-dropdown-form">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="user-dropdown-item user-dropdown-danger" role="menuitem">
                                    <i class="fas fa-right-from-bracket"></i>
                                    <span>Cerrar sesion</span>
                                </button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <a href="/Account/Login" class="btn btn-primary">
                        <i class="fas fa-sign-in-alt" style="margin-right: 0.5rem;"></i> <span class="navbar-login-label">Iniciar Sesión</span>
                    </a>
                }
            </div>
        </div>
    </nav>
    }


    
    <main class="app-main page-enter">
        @RenderBody()
    </main>

    
    <footer class="footer">
        <div class="footer-content">
            <div>
                <h4 class="footer-title">
                    <i class="fas fa-crown" style="margin-right: 0.5rem;"></i> BakeSmart Patri
                </h4>
                <p style="color: rgba(255,255,255,0.7); font-size: 0.875rem; line-height: 1.6; margin-bottom: 1.5rem;">
                    Transformando la gestión de reposterías con tecnología inteligente y diseño moderno.
                </p>
                <div style="display: flex; gap: 1rem;">
                    <a href="#" style="color: white; font-size: 1.25rem;"><i class="fab fa-facebook"></i></a>
                    <a href="#" style="color: white; font-size: 1.25rem;"><i class="fab fa-instagram"></i></a>
                    <a href="#" style="color: white; font-size: 1.25rem;"><i class="fab fa-whatsapp"></i></a>
                </div>
            </div>

            <div>
                <h4 class="footer-title">Productos</h4>
                <ul class="footer-links">
                    <li><a href="/Catalog"><i class="fas fa-chevron-right" style="font-size: 0.75rem; margin-right: 0.5rem;"></i> Catálogo completo</a></li>
                    <li><a href="/Catalog"><i class="fas fa-chevron-right" style="font-size: 0.75rem; margin-right: 0.5rem;"></i> Productos activos</a></li>
                    <li><a href="/Orders/Create"><i class="fas fa-chevron-right" style="font-size: 0.75rem; margin-right: 0.5rem;"></i> Crear pedido</a></li>
                    <li><a href="/Client/Orders"><i class="fas fa-chevron-right" style="font-size: 0.75rem; margin-right: 0.5rem;"></i> Mis pedidos</a></li>
                </ul>
            </div>

            <div>
                <h4 class="footer-title">Soporte</h4>
                <ul class="footer-links">
                    <li><a href="/Home/About"><i class="fas fa-chevron-right" style="font-size: 0.75rem; margin-right: 0.5rem;"></i> Acerca de</a></li>
                    <li><a href="/Home/Contact"><i class="fas fa-chevron-right" style="font-size: 0.75rem; margin-right: 0.5rem;"></i> Contacto</a></li>
                    <li><a href="/Home/Terms"><i class="fas fa-chevron-right" style="font-size: 0.75rem; margin-right: 0.5rem;"></i> Términos y condiciones</a></li>
                    <li><a href="/Home/Privacy"><i class="fas fa-chevron-right" style="font-size: 0.75rem; margin-right: 0.5rem;"></i> Política de privacidad</a></li>
                </ul>
            </div>

            <div>
                <h4 class="footer-title">Contacto</h4>
                <ul class="footer-links">
                    <li><i class="fas fa-phone" style="width: 20px; margin-right: 0.5rem;"></i> +506 8888-8888</li>
                    <li><i class="fas fa-envelope" style="width: 20px; margin-right: 0.5rem;"></i> info@bakesmart.com</li>
                    <li><i class="fas fa-map-marker-alt" style="width: 20px; margin-right: 0.5rem;"></i> San José, Costa Rica</li>
                    <li><i class="fas fa-clock" style="width: 20px; margin-right: 0.5rem;"></i> Lun-Vie: 8am - 6pm</li>
                </ul>
            </div>
        </div>

        <div class="footer-bottom">
            <p>© 2026 BakeSmart Patri. Todos los derechos reservados. Diseñado con <i class="fas fa-heart" style="color: var(--secondary);"></i> para reposteros.</p>
        </div>
    </footer>

    
    <div id="toastContainer" style="position: fixed; bottom: 20px; right: 20px; z-index: 9999;"></div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/bakesmart-store.js" asp-append-version="true"></script>
    <script src="~/js/smart-tables.js" asp-append-version="true"></script>

    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
