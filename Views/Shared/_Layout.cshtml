    <div id="toastContainer" style="position: fixed; bottom: 20px; right: 20px; z-index: 9999;"></div>

    <div class="global-categories-backdrop" id="globalCategoriesBackdrop" hidden></div>
    <aside class="global-categories-sidebar" id="globalCategoriesSidebar" aria-hidden="true" aria-labelledby="globalCategoriesTitle">
        <div class="global-categories-sidebar__header">
            <div>
                <span>Catalogo</span>
                <h2 id="globalCategoriesTitle">Todas las categorias</h2>
            </div>
            <button class="global-categories-close" type="button" id="globalCategoriesClose" aria-label="Cerrar categorias">
                <i class="fas fa-xmark"></i>
            </button>
        </div>
        <div class="global-categories-sidebar__body" id="globalCategoriesList">
            <div class="global-categories-loading">Cargando categorias...</div>
        </div>
    </aside>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/bakesmart-store.js" asp-append-version="true"></script>
    <script src="~/js/smart-tables.js" asp-append-version="true"></script>
    <script>
        (() => {
            const sidebar = document.getElementById('globalCategoriesSidebar');
            const backdrop = document.getElementById('globalCategoriesBackdrop');
            const closeButton = document.getElementById('globalCategoriesClose');
            const list = document.getElementById('globalCategoriesList');
            let loaded = false;

            const clean = value => String(value ?? '').replace(/[&<>"']/g, char => ({
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#039;'
            })[char]);

            async function loadCategories() {
                if (loaded) return;
                try {
                    const response = await fetch('/api/catalog/options');
                    if (!response.ok) throw new Error('No se pudieron cargar las categorias.');
                    const contentType = response.headers.get('content-type') || '';
                    if (!contentType.includes('application/json')) throw new Error('El catalogo devolvio una respuesta invalida.');
                    const data = await response.json();
                    const categories = data.categories || [];
                    const products = data.products || [];
                    list.innerHTML = `
                        <a class="global-category-option global-category-option--active" href="/Catalog">
                            <span><i class="fas fa-th-large"></i></span>
                            <strong>Todas las categorias</strong>
                            <small>${products.length} productos</small>
                        </a>
                        ${categories.map(category => {
                            const count = products.filter(product => product.category === category.name || product.Category === category.name).length;
                            const url = category.url || `/Catalog?category=${encodeURIComponent(category.name)}`;
                            return `
                                <a class="global-category-option" href="${url}">
                                    <span><i class="fas ${clean(category.icon || 'fa-cake-candles')}"></i></span>
                                    <strong>${clean(category.name)}</strong>
                                    <small>${count} productos</small>
                                </a>
                            `;
                        }).join('')}
                    `;
                    loaded = true;
                } catch (error) {
                    list.innerHTML = `<div class="global-categories-loading">${clean(error.message)}</div>`;
                }
            }

            async function openGlobalCategories(event) {
                if (event) event.preventDefault();
                await loadCategories();
                sidebar.classList.add('is-open');
                sidebar.setAttribute('aria-hidden', 'false');
                backdrop.hidden = false;
                document.body.classList.add('global-categories-open');
            }

            function closeGlobalCategories() {
                sidebar.classList.remove('is-open');
                sidebar.setAttribute('aria-hidden', 'true');
                backdrop.hidden = true;
                document.body.classList.remove('global-categories-open');
            }

            document.querySelectorAll('[data-open-global-categories]').forEach(link => {
                link.addEventListener('click', openGlobalCategories);
            });
            closeButton?.addEventListener('click', closeGlobalCategories);
            backdrop?.addEventListener('click', closeGlobalCategories);
            document.addEventListener('keydown', event => {
                if (event.key === 'Escape') closeGlobalCategories();
            });

            window.BakeSmartOpenCategories = openGlobalCategories;
        })();
    </script>

    
